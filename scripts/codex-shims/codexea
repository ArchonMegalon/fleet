if [ "${#ADJUSTED_ARGS[@]}" -gt 0 ] && args_request_interactive_session "${ADJUSTED_ARGS[@]}"; then
  INTERACTIVE_SESSION_WITH_FLAGS=1
  mapfile -d '' INTERACTIVE_SESSION_ARGS < <(strip_interactive_request_flags "${ADJUSTED_ARGS[@]}")
else
  INTERACTIVE_SESSION_ARGS=()
fi
PROMPT_TRACE_HEARTBEAT_REQUEST=1
if [ "${INTERACTIVE_SESSION_WITH_FLAGS}" -eq 1 ]; then
  if [ -z "${TMUX-}" ] || ([ -t 0 ] && [ -t 1 ]); then
    PROMPT_TRACE_HEARTBEAT_REQUEST=0
  fi
fi
if [ "${INTERACTIVE_SESSION_REQUEST}" -eq 1 ] || [ "${RESUME_SESSION_REQUEST}" -eq 1 ]; then
  PROMPT_TRACE_HEARTBEAT_REQUEST=0
fi

if [ "${#ADJUSTED_ARGS[@]}" -eq 0 ] && [ -n "${CODEXEA_WATCHDOG_ACTIVE:-}" ] && { [ -n "${CODEXEA_WATCHDOG_RESUME_SESSION_ID:-}" ] || [ -n "${CODEXEA_WATCHDOG_RESUME_PROMPT+x}" ]; }; then
  CODEXEA_CMD=("${REAL_CODEX}" "${INTERACTIVE_ARGS[@]}" "${BASE_PROFILE_ARGS[@]}" "${EA_DEFAULT_ARGS[@]}")
  if [ -n "${CODEXEA_WATCHDOG_RESUME_SESSION_ID:-}" ]; then
    if [ -n "${CODEXEA_WATCHDOG_RESUME_PROMPT}" ]; then
      CODEXEA_CMD+=(resume "${CODEXEA_WATCHDOG_RESUME_SESSION_ID}" "${CODEXEA_WATCHDOG_RESUME_PROMPT}")
    else
      CODEXEA_CMD+=(resume "${CODEXEA_WATCHDOG_RESUME_SESSION_ID}")
    fi
  elif [ -n "${CODEXEA_WATCHDOG_RESUME_PROMPT}" ]; then
    CODEXEA_CMD+=(resume --last "${CODEXEA_WATCHDOG_RESUME_PROMPT}")
  else
    CODEXEA_CMD+=(resume --last)
  fi
elif [ "${#ADJUSTED_ARGS[@]}" -eq 0 ] && [ -n "${CODEXEA_WATCHDOG_ACTIVE:-}" ]; then
  CODEXEA_CMD=("${REAL_CODEX}" "${INTERACTIVE_ARGS[@]}" "${BASE_PROFILE_ARGS[@]}" "${EA_DEFAULT_ARGS[@]}")
  if [ -n "${CODEXEA_STARTUP_PROMPT}" ]; then
    CODEXEA_CMD+=("${CODEXEA_STARTUP_PROMPT}")
  fi
elif [ "${INTERACTIVE_SESSION_WITH_FLAGS}" -eq 1 ]; then
  CODEXEA_CMD=("${REAL_CODEX}" "${INTERACTIVE_ARGS[@]}" "${BASE_PROFILE_ARGS[@]}" "${EA_DEFAULT_ARGS[@]}" "${INTERACTIVE_SESSION_ARGS[@]}")
elif [ "${RESUME_SESSION_REQUEST}" -eq 1 ]; then
  CODEXEA_CMD=("${REAL_CODEX}" "${INTERACTIVE_ARGS[@]}" "${BASE_PROFILE_ARGS[@]}" "${EA_DEFAULT_ARGS[@]}" "${ADJUSTED_ARGS[@]}")
elif [ "${EXEC_SESSION_REQUEST}" -eq 1 ]; then
  CODEXEA_CMD=("${REAL_CODEX}" "${BASE_PROFILE_ARGS[@]}" "${EA_DEFAULT_ARGS[@]}" "${EXEC_SESSION_ARGS[@]}")
  if [ "${#ADJUSTED_ARGS[@]}" -gt 0 ] && [ -z "${CODEXEA_POST_AUDIT_OBJECTIVE:-}" ]; then
    export CODEXEA_POST_AUDIT_OBJECTIVE="${ADJUSTED_ARGS[*]}"
  fi
elif [ "${INTERACTIVE_SESSION_REQUEST}" -eq 1 ] && [ "${#ADJUSTED_ARGS[@]}" -gt 0 ]; then
  CODEXEA_CMD=("${REAL_CODEX}" "${INTERACTIVE_ARGS[@]}" "${BASE_PROFILE_ARGS[@]}" "${EA_DEFAULT_ARGS[@]}" "${ADJUSTED_ARGS[@]}")
elif [ "${#ADJUSTED_ARGS[@]}" -eq 0 ]; then
  CODEXEA_CMD=("${REAL_CODEX}" "${INTERACTIVE_ARGS[@]}" "${BASE_PROFILE_ARGS[@]}" "${EA_DEFAULT_ARGS[@]}")
  if [ -n "${CODEXEA_STARTUP_PROMPT}" ]; then
    CODEXEA_CMD+=("${CODEXEA_STARTUP_PROMPT}")
  fi
  if [ -z "${CODEXEA_POST_AUDIT_OBJECTIVE:-}" ]; then
    export CODEXEA_POST_AUDIT_OBJECTIVE="Bootstrap interactive CodexEA session in $(pwd)."
  fi
else
  CODEXEA_CMD=("${REAL_CODEX}" "${BASE_PROFILE_ARGS[@]}" "${EA_DEFAULT_ARGS[@]}" "${ADJUSTED_ARGS[@]}")
  if [ "${#ADJUSTED_ARGS[@]}" -gt 0 ] && [ -z "${CODEXEA_POST_AUDIT_OBJECTIVE:-}" ]; then
    export CODEXEA_POST_AUDIT_OBJECTIVE="${ADJUSTED_ARGS[*]}"
  fi
fi

emit_startup_trace "$(
  if [ "${RESUME_SESSION_REQUEST}" -eq 1 ]; then
    printf '%s' "start_resume_session"
  elif [ "${EXEC_SESSION_REQUEST}" -eq 1 ] || [ "${EXPLICIT_EXEC_SUBCOMMAND_REQUEST}" -eq 1 ]; then
    if [ "${RAW_INTERACTIVE_SESSION_REQUEST}" -eq 1 ] && [ "${NON_TTY_NOARG_INTERACTIVE_FALLBACK}" -eq 1 ] && [ -z "${CODEXEA_TRACE_HEARTBEAT_SECONDS+x}" ]; then
      printf '%s' "start_interactive_session"
    else
      printf '%s' "start_exec_session"
    fi
  elif [ "${INTERACTIVE_SESSION_REQUEST}" -eq 1 ]; then
    printf '%s' "start_interactive_session"
  else
    printf '%s' "start_prompt_session"
  fi
)"

USE_CLEAN_EXEC_OUTPUT=0
if [ "${CODEXEA_CLEAN_EXEC_OUTPUT:-1}" = "1" ] && ! args_request_raw_exec_output "${ADJUSTED_ARGS[@]}"; then
  if [ "${EXEC_SESSION_REQUEST}" -eq 1 ] || [ "${EXPLICIT_EXEC_SUBCOMMAND_REQUEST}" -eq 1 ]; then
    if [ "${INTERACTIVE_SESSION_REQUEST}" -eq 0 ]; then
      USE_CLEAN_EXEC_OUTPUT=1
    fi
  fi
fi

if [ "${POST_AUDIT_THIS_RUN}" -eq 1 ] && capture_post_audit_context; then
  set +e
  if [ "${USE_CLEAN_EXEC_OUTPUT}" -eq 1 ]; then
    run_exec_session_with_clean_output "${CODEXEA_CMD[@]}"
  elif [ "${PROMPT_TRACE_HEARTBEAT_REQUEST}" -eq 1 ]; then
    run_with_trace_heartbeat "${CODEXEA_CMD[@]}"
  else
    "${CODEXEA_CMD[@]}"
  fi
  CODEXEA_EXIT=$?
  set -e
  export CODEXEA_POST_AUDIT_EXIT_CODE="${CODEXEA_EXIT}"
  REVIEW_REQUEST_FILE="${CODEXEA_STATE_DIR}/post-audit-latest.json"
  rm -f "${REVIEW_REQUEST_FILE}"
  if build_post_audit_request "${REVIEW_REQUEST_FILE}"; then
    emit_post_audit_request "${REVIEW_REQUEST_FILE}"
  fi
  exit "${CODEXEA_EXIT}"
fi

if [ "${USE_CLEAN_EXEC_OUTPUT}" -eq 1 ]; then
  set +e
  run_exec_session_with_clean_output "${CODEXEA_CMD[@]}"
  CODEXEA_EXIT=$?
  set -e
  exit "${CODEXEA_EXIT}"
fi

if [ "${PROMPT_TRACE_HEARTBEAT_REQUEST}" -eq 1 ]; then
  set +e
  run_with_trace_heartbeat "${CODEXEA_CMD[@]}"
  CODEXEA_EXIT=$?
  set -e
  exit "${CODEXEA_EXIT}"
fi

exec "${CODEXEA_CMD[@]}"
