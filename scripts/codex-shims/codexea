import sys
import urllib.error
import urllib.request

lane = str(sys.argv[1] or "").strip().lower()
profile_by_lane = {
    "easy": "easy",
    "repair": "repair",
    "groundwork": "groundwork",
    "core": str(os.environ.get("CODEXEA_CORE_RESPONSES_PROFILE") or "core").strip().lower() or "core",
    "core_rescue": "core_rescue",
    "jury": "audit",
    "survival": "survival",
}
profile_name = profile_by_lane.get(lane, lane)
if not profile_name:
    raise SystemExit(1)

root = str(os.environ.get("EA_MCP_BASE_URL") or "http://127.0.0.1:8090").rstrip("/")
url = str(os.environ.get("CODEXEA_PROFILES_URL") or f"{root}/v1/codex/profiles").strip()
principal_id = (
    str(os.environ.get("EA_MCP_PRINCIPAL_ID") or "").strip()
    or str(os.environ.get("EA_PRINCIPAL_ID") or "").strip()
    or "codexea-shim"
)
headers = {"X-EA-Principal-ID": principal_id}
api_token = str(os.environ.get("EA_MCP_API_TOKEN") or os.environ.get("EA_API_TOKEN") or "").strip()
if api_token:
    headers["Authorization"] = f"Bearer {api_token}"
    headers["X-EA-Api-Token"] = api_token
    headers["X-API-Token"] = api_token
request = urllib.request.Request(url, headers=headers, method="GET")
try:
    with urllib.request.urlopen(request, timeout=1.0) as response:
        payload = json.loads(response.read().decode("utf-8"))
except (urllib.error.URLError, TimeoutError, ValueError, OSError):
    raise SystemExit(1)

profiles = payload.get("profiles")
if not isinstance(profiles, list):
    raise SystemExit(1)

for item in profiles:
    if not isinstance(item, dict):
        continue
    if str(item.get("profile") or "").strip().lower() != profile_name:
        continue
    model = str(item.get("model") or "").strip()
    if model:
        print(model)
        raise SystemExit(0)

raise SystemExit(1)
PY
}

inject_bootstrap_prompt() {
  local -a args=("$@")
  local i=0
  local idx=-1
  local prompt_prefix=""

  [ "${#args[@]}" -gt 0 ] || return 0
  args_request_interactive_session "${args[@]}" && {
    printf '%s\0' "${args[@]}"
    return
  }

  prompt_prefix="$(build_exec_trace_prompt)"
  if [ -z "${prompt_prefix}" ]; then
    printf '%s\0' "${args[@]}"
    return
  fi

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --)
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          idx="${i}"
        fi
        break
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir)
        i=$((i + 2))
        ;;
      --interactive|--oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|-h|--help|-V|--version)
        i=$((i + 1))
        ;;
      -*)
        printf '%s\0' "${args[@]}"
        return
        ;;
      *)
        idx="${i}"
        break
        ;;
    esac
  done

  if [ "${idx}" -lt 0 ]; then
    printf '%s\0' "${args[@]}"
    return
  fi

  if is_codex_subcommand "${args[$idx]}"; then
    printf '%s\0' "${args[@]}"
    return
  fi

  args[$idx]="${prompt_prefix}"$'\n\n'"${args[$idx]}"
  printf '%s\0' "${args[@]}"
}

