    printf '%s\n' '# Auto-generated by codexea operator guard'
    printf '%s\n' "export CHUMMER_DESIGN_SUPERVISOR_REDIRECT_HELPER=${quoted_redirect}"
    printf '%s\n' "export CHUMMER_DESIGN_SUPERVISOR_TASK_LOCAL_TELEMETRY_PATH=${quoted_telemetry}"
    printf '%s\n' "export CHUMMER_DESIGN_SUPERVISOR_EXEC_STRING_HIT_COUNTER=${quoted_counter}"
    printf '%s\n' 'if [[ -n "${BASH_EXECUTION_STRING:-}"'
    printf '%s\n' '  && -f "${CHUMMER_DESIGN_SUPERVISOR_TASK_LOCAL_TELEMETRY_PATH:-}"'
    printf '%s\n' '  && ( "${BASH_EXECUTION_STRING}" == *"python3 /docker/fleet/scripts/chummer_design_supervisor.py status"*'
    printf '%s\n' '    || "${BASH_EXECUTION_STRING}" == *"python3 /docker/fleet/scripts/chummer_design_supervisor.py eta"* )'
