#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_CODEX_SHIM="${CODEXLIZ_BASE_CODEX_SHIM:-${SCRIPT_DIR}/codex}"
PROXY_SCRIPT="${CODEXLIZ_PROXY_SCRIPT:-${SCRIPT_DIR}/codexliz-http-proxy}"
PROXY_PYTHON="${CODEXLIZ_PROXY_PYTHON:-/usr/bin/python3}"
CODEXLIZ_PROVIDER_KEY="${CODEXLIZ_PROVIDER_KEY:-liz}"
CODEXLIZ_PROVIDER_NAME="${CODEXLIZ_PROVIDER_NAME:-Liz Ollama}"
CODEXLIZ_BASE_URL="${CODEXLIZ_BASE_URL:-https://code.girschele.com}"
CODEXLIZ_MODEL="${CODEXLIZ_MODEL:-qwen3-coder-next:q8_0}"
CODEXLIZ_API_KEY_ENV_VAR="${CODEXLIZ_API_KEY_ENV_VAR:-CODEXLIZ_API_KEY}"
CODEXLIZ_PROXY_HOST="${CODEXLIZ_PROXY_HOST:-127.0.0.1}"
CODEXLIZ_PROXY_PORT="${CODEXLIZ_PROXY_PORT:-}"
CODEXLIZ_STATE_DIR="${CODEXLIZ_STATE_DIR:-${HOME}/.cache/codexliz}"
CODEXLIZ_PROXY_PID_FILE="${CODEXLIZ_PROXY_PID_FILE:-${CODEXLIZ_STATE_DIR}/proxy.pid}"
CODEXLIZ_PROXY_LOG_FILE="${CODEXLIZ_PROXY_LOG_FILE:-${CODEXLIZ_STATE_DIR}/proxy.log}"
CODEXLIZ_PROXY_PORT_FILE="${CODEXLIZ_PROXY_PORT_FILE:-${CODEXLIZ_STATE_DIR}/proxy.port}"
CODEXLIZ_PREFLIGHT_MODELS_PATH="${CODEXLIZ_PREFLIGHT_MODELS_PATH:-/v1/models}"
CODEXLIZ_PREFLIGHT_TIMEOUT_SECONDS="${CODEXLIZ_PREFLIGHT_TIMEOUT_SECONDS:-5}"
CODEXLIZ_CF_ACCESS_FILE="${CODEXLIZ_CF_ACCESS_FILE:-/docker/fleet/secrets/codexliz-cf-access.env}"
CODEXLIZ_CF_ACCESS_CLIENT_ID="${CODEXLIZ_CF_ACCESS_CLIENT_ID:-}"
CODEXLIZ_CF_ACCESS_CLIENT_SECRET="${CODEXLIZ_CF_ACCESS_CLIENT_SECRET:-}"
CODEXLIZ_TRANSPORT_RETRY_ENABLED="${CODEXLIZ_TRANSPORT_RETRY_ENABLED:-1}"
CODEXLIZ_TRANSPORT_RETRY_INTERVAL_SECONDS="${CODEXLIZ_TRANSPORT_RETRY_INTERVAL_SECONDS:-60}"
CODEXLIZ_TRANSPORT_RETRY_BACKOFF_MAX_SECONDS="${CODEXLIZ_TRANSPORT_RETRY_BACKOFF_MAX_SECONDS:-300}"
CODEXLIZ_TRANSPORT_RETRY_MAX_WAIT_SECONDS="${CODEXLIZ_TRANSPORT_RETRY_MAX_WAIT_SECONDS:-86400}"
CODEXLIZ_TRANSPORT_TRACE_INTERVAL_SECONDS="${CODEXLIZ_TRANSPORT_TRACE_INTERVAL_SECONDS:-5}"
CODEXLIZ_TRANSPORT_REQUIRE_EMPTY_OUTPUT_FOR_RETRY="${CODEXLIZ_TRANSPORT_REQUIRE_EMPTY_OUTPUT_FOR_RETRY:-1}"
CODEXLIZ_OUTAGE_STATE_FILE="${CODEXLIZ_OUTAGE_STATE_FILE:-${CODEXLIZ_STATE_DIR}/outage.json}"
CODEXLIZ_DEBUG="${CODEXLIZ_DEBUG:-0}"
CODEXLIZ_DEBUG_LOG_FILE="${CODEXLIZ_DEBUG_LOG_FILE:-${CODEXLIZ_STATE_DIR}/debug.log}"
CODEXLIZ_ACTIVE_CHILD_PID=""

if [ ! -x "${BASE_CODEX_SHIM}" ]; then
  FALLBACK_CODEX_SHIM="${CODEXLIZ_FALLBACK_CODEX_SHIM:-${CODEX_REAL_BIN:-}}"
  if [ -z "${FALLBACK_CODEX_SHIM}" ]; then
    FALLBACK_CODEX_SHIM="$(command -v codex || true)"
  fi
  if [ -n "${FALLBACK_CODEX_SHIM}" ] && [ "${FALLBACK_CODEX_SHIM}" != "$0" ] && [ -x "${FALLBACK_CODEX_SHIM}" ]; then
    BASE_CODEX_SHIM="${FALLBACK_CODEX_SHIM}"
  fi
fi

if [ ! -x "${BASE_CODEX_SHIM}" ]; then
  echo "Missing base codex shim at ${BASE_CODEX_SHIM}" >&2
  exit 1
fi

if [ ! -x "${PROXY_PYTHON}" ]; then
  echo "Missing python runtime for codexliz proxy at ${PROXY_PYTHON}" >&2
  exit 1
fi

env_truthy() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

debug_render_args() {
  python3 - "$@" <<'PY'
import shlex
import sys

parts = []
for arg in sys.argv[1:]:
    display = arg
    if "\n" in display or len(display) > 120:
        display = f"<arg:{len(arg)} chars>"
    parts.append(shlex.quote(display))
print(" ".join(parts))
PY
}

emit_debug_trace() {
  local detail="${1:-}"
  local line=""
  env_truthy "${CODEXLIZ_DEBUG}" || return 0
  mkdir -p "${CODEXLIZ_STATE_DIR}" >/dev/null 2>&1 || true
  line="Trace: provider=${CODEXLIZ_PROVIDER_KEY} debug=${detail}"
  printf '%s\n' "${line}" >&2
  printf '%s\n' "${line}" >> "${CODEXLIZ_DEBUG_LOG_FILE}" 2>/dev/null || true
}

emit_debug_command() {
  local phase="${1:-launch}"
  local rendered=""
  shift || true
  env_truthy "${CODEXLIZ_DEBUG}" || return 0
  rendered="$(debug_render_args "$@")"
  emit_debug_trace "${phase} command=${rendered}"
}

positive_integer_or_default() {
  local value="${1:-}"
  local fallback="${2:-0}"
  if [[ "${value}" =~ ^[0-9]+$ ]]; then
    printf '%s' "${value}"
    return
  fi
  printf '%s' "${fallback}"
}

normalize_remote_upstream_base_url() {
  local url="${1:-}"
  url="${url#"${url%%[![:space:]]*}"}"
  url="${url%"${url##*[![:space:]]}"}"
  if [ -z "${url}" ]; then
    url="https://code.girschele.com"
  fi
  if [[ "${url}" != *"://"* ]]; then
    url="https://${url}"
  fi
  url="${url%/}"
  if [[ "${url}" == */v1 ]]; then
    url="${url%/v1}"
  fi
  printf '%s' "${url}"
}

normalize_access_token_value() {
  local value="${1:-}"
  if [[ "${value}" == REPLACE_WITH_* ]]; then
    printf ''
    return
  fi
  printf '%s' "${value}"
}

load_cf_access_env() {
  local env_file="${CODEXLIZ_CF_ACCESS_FILE:-}"
  if [ -z "${CODEXLIZ_CF_ACCESS_CLIENT_ID:-}" ] && [ -z "${CODEXLIZ_CF_ACCESS_CLIENT_SECRET:-}" ] && [ -n "${env_file}" ] && [ -f "${env_file}" ]; then
    set -a
    . "${env_file}"
    set +a
  fi

  CODEXLIZ_CF_ACCESS_CLIENT_ID="$(normalize_access_token_value "${CODEXLIZ_CF_ACCESS_CLIENT_ID:-${CF_ACCESS_CLIENT_ID:-}}")"
  CODEXLIZ_CF_ACCESS_CLIENT_SECRET="$(normalize_access_token_value "${CODEXLIZ_CF_ACCESS_CLIENT_SECRET:-${CF_ACCESS_CLIENT_SECRET:-}}")"
  export CODEXLIZ_CF_ACCESS_CLIENT_ID CODEXLIZ_CF_ACCESS_CLIENT_SECRET

  if { [ -n "${CODEXLIZ_CF_ACCESS_CLIENT_ID}" ] && [ -z "${CODEXLIZ_CF_ACCESS_CLIENT_SECRET}" ]; } || { [ -z "${CODEXLIZ_CF_ACCESS_CLIENT_ID}" ] && [ -n "${CODEXLIZ_CF_ACCESS_CLIENT_SECRET}" ]; }; then
    echo "codexliz Cloudflare Access config requires both client id and client secret" >&2
    exit 1
  fi
}

build_local_provider_base_url() {
  local proxy_port="${1:-}"
  printf 'http://%s:%s/v1' "${CODEXLIZ_PROXY_HOST}" "${proxy_port}"
}

build_preflight_url() {
  local base_url="${1:-}"
  local path="${2:-/v1/models}"
  base_url="${base_url%/}"
  if [[ "${base_url}" == */v1 ]] && [[ "${path}" == /v1/* ]]; then
    printf '%s%s' "${base_url}" "${path#/v1}"
    return
  fi
  printf '%s%s' "${base_url}" "${path}"
}

is_providerless_command() {
  case "${1:-}" in
    login|logout|mcp|mcp-server|app-server|completion|sandbox|debug|features|help|marketplace)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

detect_primary_command() {
  local -a args=("$@")
  local i=0

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --)
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          printf '%s' "${args[$i]}"
        fi
        return
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir|--remote|--remote-auth-token-env)
        i=$((i + 2))
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|-h|--help|-V|--version)
        i=$((i + 1))
        ;;
      -*)
        i=$((i + 1))
        ;;
      *)
        printf '%s' "${args[$i]}"
        return
        ;;
    esac
  done
}

has_explicit_provider_override() {
  local -a args=("$@")
  local i=0
  local value=""

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --oss|--local-provider)
        return 0
        ;;
      -c|--config)
        i=$((i + 1))
        if [ "${i}" -ge "${#args[@]}" ]; then
          break
        fi
        value="${args[$i]}"
        case "${value}" in
          *model_provider*|*model_providers.*|*chatgpt_base_url*|*openai_base_url*)
            return 0
            ;;
        esac
        ;;
    esac
    i=$((i + 1))
  done

  return 1
}

has_explicit_model_override() {
  local -a args=("$@")
  local i=0
  local value=""

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      -m|--model)
        return 0
        ;;
      -c|--config)
        i=$((i + 1))
        if [ "${i}" -ge "${#args[@]}" ]; then
          break
        fi
        value="${args[$i]}"
        case "${value}" in
          model=*|\"model\"=*|\'model\'=*)
            return 0
            ;;
        esac
        ;;
    esac
    i=$((i + 1))
  done

  return 1
}

process_is_running() {
  local pid="${1:-}"
  [ -n "${pid}" ] || return 1
  kill -0 "${pid}" 2>/dev/null
}

cleanup_active_codex_child() {
  local pid="${CODEXLIZ_ACTIVE_CHILD_PID:-}"
  local attempt=0
  if [ -z "${pid}" ]; then
    return 0
  fi
  CODEXLIZ_ACTIVE_CHILD_PID=""
  if ! process_is_running "${pid}"; then
    return 0
  fi
  kill "${pid}" >/dev/null 2>&1 || true
  while [ "${attempt}" -lt 20 ] && process_is_running "${pid}"; do
    sleep 0.1
    attempt=$((attempt + 1))
  done
  if process_is_running "${pid}"; then
    kill -KILL "${pid}" >/dev/null 2>&1 || true
  fi
}

run_codex_child_with_stderr_capture() {
  local stderr_file="${1:-}"
  local stdin_path="${2:-}"
  shift 2
  local -a cmd=("$@")
  local child_pid=""
  local exit_code=0

  if [ -n "${stdin_path}" ] && [ -f "${stdin_path}" ]; then
    "${cmd[@]}" < "${stdin_path}" 2> >(tee "${stderr_file}" >&2) &
  else
    "${cmd[@]}" 2> >(tee "${stderr_file}" >&2) &
  fi
  child_pid="$!"
  CODEXLIZ_ACTIVE_CHILD_PID="${child_pid}"
  wait "${child_pid}"
  exit_code=$?
  if [ "${CODEXLIZ_ACTIVE_CHILD_PID:-}" = "${child_pid}" ]; then
    CODEXLIZ_ACTIVE_CHILD_PID=""
  fi
  return "${exit_code}"
}

trap cleanup_active_codex_child EXIT HUP INT TERM

