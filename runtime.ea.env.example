# Non-secret defaults for wiring EA into Fleet via the local MCP bridge.
# Copy this file to `runtime.ea.env` for local runtime use.
# Override any of these in the ignored `runtime.env` if needed.
EA_MCP_BASE_URL=http://host.docker.internal:8090
EA_MCP_API_TOKEN=
EA_MCP_PRINCIPAL_ID=
EA_BASE_URL=http://host.docker.internal:8090
EA_API_TOKEN=
EA_PRINCIPAL_ID=
EA_MCP_TIMEOUT_SECONDS=30
EA_MCP_MODEL=
EA_RESPONSES_HARD_MAX_ACTIVE_REQUESTS=20
