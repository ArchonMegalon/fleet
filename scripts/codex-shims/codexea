    printf '%s\n' 'fi'
    printf '%s\n' "python3() { \"${quoted_shim}\" \"\$@\"; }"
    printf '%s\n' 'export -f python3'
  } > "${bash_env_path}"
  printf '%s' "${bash_env_path}"
}

write_operator_guard_home() {
  local run_dir="$1"
  local bash_env_path="$2"
  local original_home="${3:-}"
  local guard_home="${run_dir}/home"
  local name=""
  local source_path=""
  local target_path=""
  local quoted_bash_env=""

  mkdir -p "${guard_home}" || return 1
  for name in .codex .config .cache .local .gitconfig .ssh .openai; do
    source_path="${original_home%/}/${name}"
    target_path="${guard_home}/${name}"
    [ -e "${source_path}" ] || continue
    ln -s "${source_path}" "${target_path}" 2>/dev/null || true
  done
  printf -v quoted_bash_env '%q' "${bash_env_path}"
  {
    printf '%s\n' '# Auto-generated by codexea operator guard'
    printf '%s\n' "source ${quoted_bash_env}"
  } > "${guard_home}/.bash_profile"
  cp "${guard_home}/.bash_profile" "${guard_home}/.profile" >/dev/null 2>&1 || true
  printf '%s' "${guard_home}"
}

