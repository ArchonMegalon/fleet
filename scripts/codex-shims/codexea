inside_git_repository() {
  git -C "${PWD:-.}" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

select_default_workdir() {
  local candidate=""
  local explicit="${CODEXEA_NO_REPO_WORKDIR-}"
  local -a candidates=(
    "${explicit}"
    "/docker/fleet"
    "/docker/chummercomplete"
    "/docker/fleet/repos"
    "${HOME:-/home/$(id -un)}"
  )

  for candidate in "${candidates[@]}"; do
    [ -n "${candidate}" ] || continue
    if [ ! -d "${candidate}" ]; then
      continue
    fi
    if git -C "${candidate}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      printf '%s' "${candidate}"
      return 0
    fi
  done

  return 1
}

detect_primary_command() {
  local -a args=("$@")
  local i=0

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --)
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          printf '%s' "${args[$i]}"
        fi
        return
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir)
        i=$((i + 2))
        ;;
      --interactive|--oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|-h|--help|-V|--version)
        i=$((i + 1))
        ;;
      -*)
        i=$((i + 1))
        ;;
      *)
        printf '%s' "${args[$i]}"
        return
        ;;
    esac
  done
}

is_codex_subcommand() {
  case "${1:-}" in
    exec|review|login|logout|mcp|mcp-server|app-server|completion|sandbox|debug|apply|resume|fork|cloud|features|help)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

has_explicit_profile_override() {
  local -a args=("$@")
  local i=0

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      -p|--profile)
        return 0
        ;;
      --)
        return 1
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir)
        i=$((i + 2))
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|-h|--help|-V|--version)
        i=$((i + 1))
        ;;
      *)
        i=$((i + 1))
        ;;
    esac
  done
  return 1
}

args_request_interactive_session() {
  local -a args=("$@")
  local i=0
  local saw_interactive=0
  local primary_command=""

  [ "${#args[@]}" -gt 0 ] || return 1

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --interactive)
        saw_interactive=1
        i=$((i + 1))
        ;;
      --)
        break
        ;;
    esac
    i=$((i + 1))
  done

  [ "${saw_interactive}" -eq 1 ] || return 1
  primary_command="$(detect_primary_command "$@")"
  if [ -n "${primary_command}" ] && is_codex_subcommand "${primary_command}"; then
    return 1
  fi
  return 0
}

strip_interactive_request_flags() {
  local -a args=("$@")
  local i=0

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --interactive)
        i=$((i + 1))
        ;;
      *)
        printf '%s\0' "${args[$i]}"
        i=$((i + 1))
        ;;
    esac
  done
}

has_explicit_runtime_override() {
  local -a args=("$@")
  local i=0
  local value=""
  local normalized=""

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      -m|--model|--oss|--local-provider|-p|--profile)
        return 0
        ;;
      -c|--config)
        i=$((i + 1))
        if [ "${i}" -ge "${#args[@]}" ]; then
          break
        fi
        value="${args[$i]}"
        normalized="${value//[[:space:]]/}"
        case "${normalized}" in
          model=*|model_provider=*|model_providers.*|chatgpt_base_url=*|openai_base_url=*)
            return 0
            ;;
        esac
        ;;
      --)
        return 1
        ;;
    esac
    i=$((i + 1))
  done
  return 1
}

build_base_profile_args() {
  [ "${MODE:-}" = "mcp" ] || return 0
  [ -n "${CODEXEA_BASE_PROFILE}" ] || return 0
  has_explicit_profile_override "$@" && return 0
  printf '%s\0' -p "${CODEXEA_BASE_PROFILE}"
}

build_bootstrap_prompt() {
  local prefix=""

  if [ "${CODEXEA_BOOTSTRAP}" != "0" ] && [ -r "${BOOTSTRAP_PROMPT_FILE}" ]; then
    prefix="$(cat "${BOOTSTRAP_PROMPT_FILE}")"
  fi

  printf '%s' "${prefix}"
}

build_exec_trace_prompt() {
  local prefix=""

  if [ "${CODEXEA_BOOTSTRAP}" = "0" ]; then
    return 0
  fi

  if [ -r "${CODEXEA_EXEC_TRACE_PROMPT_FILE}" ]; then
    prefix="$(cat "${CODEXEA_EXEC_TRACE_PROMPT_FILE}")"
  else
    prefix=$'Immediately print one short `Trace:` line with the current lane and the work you are starting.\nKeep emitting short one-line `Trace:` updates before each meaningful work unit and again if you have been quiet for roughly 20-45 seconds.\nWork the user request immediately after the first trace line. Do not wait for another instruction.'
  fi

  printf '%s' "${prefix}"
}

live_profile_model_for_lane() {
  local lane="$1"
  env_truthy "${CODEXEA_USE_LIVE_PROFILE_MODELS}" || return 1
  python3 - "${lane}" <<'PY'
import json
import os
import sys
import urllib.error
import urllib.request

lane = str(sys.argv[1] or "").strip().lower()
profile_by_lane = {
    "easy": "easy",
    "repair": "repair",
    "groundwork": "groundwork",
    "core": str(os.environ.get("CODEXEA_CORE_RESPONSES_PROFILE") or "core").strip().lower() or "core",
    "core_rescue": "core_rescue",
    "jury": "audit",
    "survival": "survival",
}
profile_name = profile_by_lane.get(lane, lane)
if not profile_name:
    raise SystemExit(1)

root = str(os.environ.get("EA_MCP_BASE_URL") or "http://127.0.0.1:8090").rstrip("/")
url = str(os.environ.get("CODEXEA_PROFILES_URL") or f"{root}/v1/codex/profiles").strip()
principal_id = (
    str(os.environ.get("EA_MCP_PRINCIPAL_ID") or "").strip()
    or str(os.environ.get("EA_PRINCIPAL_ID") or "").strip()
    or "codexea-shim"
)
headers = {"X-EA-Principal-ID": principal_id}
api_token = str(os.environ.get("EA_MCP_API_TOKEN") or os.environ.get("EA_API_TOKEN") or "").strip()
if api_token:
    headers["Authorization"] = f"Bearer {api_token}"
    headers["X-EA-Api-Token"] = api_token
    headers["X-API-Token"] = api_token
request = urllib.request.Request(url, headers=headers, method="GET")
try:
    with urllib.request.urlopen(request, timeout=1.0) as response:
        payload = json.loads(response.read().decode("utf-8"))
except (urllib.error.URLError, TimeoutError, ValueError, OSError):
    raise SystemExit(1)

profiles = payload.get("profiles")
if not isinstance(profiles, list):
    raise SystemExit(1)

for item in profiles:
    if not isinstance(item, dict):
        continue
    if str(item.get("profile") or "").strip().lower() != profile_name:
        continue
    model = str(item.get("model") or "").strip()
    if model:
        print(model)
        raise SystemExit(0)

raise SystemExit(1)
PY
}

inject_bootstrap_prompt() {
  local -a args=("$@")
  local i=0
  local idx=-1
  local prompt_prefix=""

  [ "${#args[@]}" -gt 0 ] || return 0
  args_request_interactive_session "${args[@]}" && {
    printf '%s\0' "${args[@]}"
    return
  }

  prompt_prefix="$(build_exec_trace_prompt)"
  if [ -z "${prompt_prefix}" ]; then
    printf '%s\0' "${args[@]}"
    return
  fi

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --)
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          idx="${i}"
        fi
        break
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir)
        i=$((i + 2))
        ;;
      --interactive|--oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|-h|--help|-V|--version)
        i=$((i + 1))
        ;;
      -*)
        printf '%s\0' "${args[@]}"
        return
        ;;
      *)
        idx="${i}"
        break
        ;;
    esac
  done

  if [ "${idx}" -lt 0 ]; then
    printf '%s\0' "${args[@]}"
    return
  fi

  if is_codex_subcommand "${args[$idx]}"; then
    printf '%s\0' "${args[@]}"
    return
  fi

  args[$idx]="${prompt_prefix}"$'\n\n'"${args[$idx]}"
  printf '%s\0' "${args[@]}"
}

args_request_exec_session() {
  local primary_command=""

  [ "$#" -gt 0 ] || return 1
  args_request_interactive_session "$@" && return 1

  primary_command="$(detect_primary_command "$@")"
  [ -n "${primary_command}" ] || return 1
  is_codex_subcommand "${primary_command}" && return 1
  return 0
}

wrap_prompt_invocation_with_exec() {
  local -a args=("$@")
  local -a exec_prefix=()
  local -a exec_only_args=()
  local -a prefix_args=()
  local arg
  local has_skip_git_repo_check=0
  local i=0

  exec_prefix=(exec)
  if env_truthy "${CODEXEA_SKIP_GIT_REPO_CHECK:-0}" && real_codex_supports_skip_git_repo_check; then
    for arg in "${args[@]}"; do
      if [ "${arg}" = "--skip-git-repo-check" ]; then
        has_skip_git_repo_check=1
        break
      fi
    done
    if [ "${has_skip_git_repo_check}" -eq 0 ]; then
      exec_prefix+=(--skip-git-repo-check)
    fi
  fi

  if [ "${#args[@]}" -gt 0 ] && [ "${args[0]}" = "exec" ]; then
    printf '%s\0' "${exec_prefix[@]}"
    if [ "${#exec_only_args[@]}" -gt 0 ]; then
      printf '%s\0' "${exec_only_args[@]}"
    fi
    printf '%s\0' "${args[@]:1}"
    return
  fi

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --json|--ephemeral)
        exec_only_args+=("${args[$i]}")
        i=$((i + 1))
        ;;
      -o|--output-last-message|--color|--output-schema)
        exec_only_args+=("${args[$i]}")
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          exec_only_args+=("${args[$i]}")
        fi
        i=$((i + 1))
        ;;
      --)
        if [ "${#prefix_args[@]}" -gt 0 ]; then
          printf '%s\0' "${prefix_args[@]}"
        fi
        printf '%s\0' "${exec_prefix[@]}"
        if [ "${#exec_only_args[@]}" -gt 0 ]; then
          printf '%s\0' "${exec_only_args[@]}"
        fi
        printf '%s\0' "${args[@]:${i}}"
        return
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir)
        prefix_args+=("${args[$i]}")
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          prefix_args+=("${args[$i]}")
        fi
        i=$((i + 1))
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|-h|--help|-V|--version)
        prefix_args+=("${args[$i]}")
        i=$((i + 1))
        ;;
      -*)
        prefix_args+=("${args[$i]}")
        i=$((i + 1))
        ;;
      *)
        if [ "${#prefix_args[@]}" -gt 0 ]; then
          printf '%s\0' "${prefix_args[@]}"
        fi
        printf '%s\0' "${exec_prefix[@]}"
        if [ "${#exec_only_args[@]}" -gt 0 ]; then
          printf '%s\0' "${exec_only_args[@]}"
        fi
        printf '%s\0' "${args[@]:${i}}"
        return
        ;;
    esac
  done

  if [ "${#prefix_args[@]}" -gt 0 ]; then
    printf '%s\0' "${prefix_args[@]}"
  fi
  printf '%s\0' "${exec_prefix[@]}"
  if [ "${#exec_only_args[@]}" -gt 0 ]; then
    printf '%s\0' "${exec_only_args[@]}"
  fi
}

append_exec_json_flag() {
  local -a args=("$@")
  local -a rendered=()
  local arg
  local inserted=0

  for arg in "${args[@]}"; do
    if [ "${arg}" = "--json" ]; then
      printf '%s\0' "${args[@]}"
      return
    fi
  done

  for arg in "${args[@]}"; do
    rendered+=("${arg}")
    if [ "${inserted}" -eq 0 ] && [ "${arg}" = "exec" ]; then
      rendered+=(--json)
      inserted=1
    fi
  done

  printf '%s\0' "${rendered[@]}"
}

args_request_raw_exec_output() {
  local -a args=("$@")
  local arg

  for arg in "${args[@]}"; do
    case "${arg}" in
      --json|-o|--output-last-message)
        return 0
        ;;
    esac
  done
  return 1
}

run_exec_session_with_clean_output() {
  local -a cmd=("$@")
  local -a json_cmd=()
  local fifo_path=""
  local stdin_file=""
  local child_pid=0
  local renderer_pid=0
  local interrupted_exit=0
  local child_exit=0
  local tick_count=0

  [ "${#cmd[@]}" -gt 0 ] || return 0
  mapfile -d '' json_cmd < <(append_exec_json_flag "${cmd[@]}")
  fifo_path="$(mktemp -u)"
  mkfifo "${fifo_path}"

  python3 "${CODEXEA_EXEC_JSON_RENDERER}" "$(pwd)" < "${fifo_path}" &
  renderer_pid=$!

  emit_waiting_trace 0
  if [ -t 0 ]; then
    "${json_cmd[@]}" < /dev/null > "${fifo_path}" 2> >(
      while IFS= read -r line; do
        if [ "${line}" != "Reading additional input from stdin..." ]; then
          printf '%s\n' "${line}" >&2
        fi
      done
    ) &
  else
    stdin_file="$(mktemp)"
    if [ -n "${CODEXEA_STDIN_PROMPT-}" ]; then
      printf '%s' "${CODEXEA_STDIN_PROMPT}" > "${stdin_file}"
    else
      cat > "${stdin_file}" || true
    fi
    "${json_cmd[@]}" < "${stdin_file}" > "${fifo_path}" 2> >(
      while IFS= read -r line; do
        if [ "${line}" != "Reading additional input from stdin..." ]; then
          printf '%s\n' "${line}" >&2
        fi
      done
    ) &
  fi
  child_pid=$!
  trap 'interrupted_exit=130; kill -INT "${child_pid}" 2>/dev/null || true' INT
  trap 'interrupted_exit=143; kill -TERM "${child_pid}" 2>/dev/null || true' TERM

  while kill -0 "${child_pid}" 2>/dev/null; do
    sleep 0.1 || break
    kill -0 "${child_pid}" 2>/dev/null || break
    tick_count=$((tick_count + 1))
    if [ "${tick_count}" -ge 250 ]; then
      emit_waiting_trace
      tick_count=0
    fi
  done

  set +e
  wait "${child_pid}"
  child_exit=$?
  wait "${renderer_pid}" 2>/dev/null
  set -e
  if [ -n "${stdin_file}" ]; then
    rm -f "${stdin_file}"
  fi
  trap - INT TERM
  rm -f "${fifo_path}"

  if [ "${interrupted_exit}" -ne 0 ]; then
    return "${interrupted_exit}"
  fi
  return "${child_exit}"
}

