}

build_exec_trace_prompt() {
  local prefix=""

  if [ "${CODEXEA_BOOTSTRAP}" = "0" ]; then
    return 0
  fi

  if [ -r "${CODEXEA_EXEC_TRACE_PROMPT_FILE}" ]; then
    prefix="$(cat "${CODEXEA_EXEC_TRACE_PROMPT_FILE}")"
  else
    prefix=$'You are Codex running through the Fleet codexea worker shim.\nOperating contract:\n- Behave like a pragmatic senior coding agent and work the assigned slice through to completion or a concrete blocker.\n- Do the work instead of announcing that you will do it.\n- Do not surface filler such as \"wait for me while i execute that command\" or other non-progress status chatter.\n- When a command is needed, run it, absorb the result, and continue the task instead of stopping at the command boundary.\n- Do not stop after a trivial probe or directory listing; use it and move the task forward.\n- Do not query supervisor status, eta, or other self-poll helpers from inside the worker run when task-local telemetry or shard handoff context is already available.\n- Use the task-local telemetry file and shard runtime handoff as the first source of context before any broader exploration.\n- If you emit progress at all, keep it short, factual, and only after a meaningful work unit or after roughly 30-45 seconds of real work.\n- Before each meaningful work unit, emit one short `Trace:` line naming the action.\n- After transient transport failures or timeouts, continue the task once the transport is back instead of abandoning it.\n- Prefer concise final answers.'
  fi

  printf '%s' "${prefix}"
}

prepend_exec_trace_stdin_prompt() {
  local prompt_prefix=""

  [ -n "${CODEXEA_STDIN_PROMPT-}" ] || return 0
  prompt_prefix="$(build_exec_trace_prompt)"
  [ -n "${prompt_prefix}" ] || return 0
  if env_truthy "${CODEXEA_OPERATOR_GUARD_ACTIVE:-0}" || [[ "${prompt_prefix}" == *"Operator-prepared "* ]]; then
    CODEXEA_STDIN_PROMPT="${prompt_prefix}"
    return 0
  fi
  case "${CODEXEA_STDIN_PROMPT}" in
    "${prompt_prefix}"*)
      return 0
      ;;
  esac
  CODEXEA_STDIN_PROMPT="${prompt_prefix}"$'\n\n'"${CODEXEA_STDIN_PROMPT}"
}

