  "recent_movement": [
    {
      "title": "Mission Control got a harder backbone.",
      "body": "Fleet shifted further toward package-scoped execution, stronger scope/capacity contracts, and a quartermaster that can reason about credits, work depth, review pressure, and drift instead of relying on ad hoc burst logic."
    },
    {
      "title": "The AI runtime got better at seeing real capacity.",
      "body": "The EA lane now exposes actual OneMinute credit posture and has been hardened around lease-aware routing, provider selection, occupancy, and review/audit scoping."
    },
    {
      "title": "The public entry story became clearer.",
      "body": "Design, Fleet, Hub, Registry, Media, and Mobile all refreshed public landing, auth, guide, and participation canon, reducing the chance that the public surface drifts away from the design source of truth."
    },
    {
      "title": "Workbench scope got easier to see.",
      "body": "The remaining desktop/browser UX work has been sliced into concrete milestone- and backlog-shaped queues instead of sitting as fuzzy later work."
    },
    {
      "title": "Core is moving from split-state cleanup toward hardening.",
      "body": "The current core wave is no longer about who owns what; it is about observability, disaster recovery, replay safety, retention, and finishing the last legacy purification passes."
    },
    {
      "title": "Cloud and publishing are now the clearest long pole.",
      "body": "The hosted stack is visibly moving, especially around public entry and email identity, but it still carries the largest remaining completion wave because registry depth, media execution, adapters, and broader hub product surfaces remain open."
    }
  ],
