wrap_prompt_invocation_with_exec() {
  local -a args=("$@")
  local -a exec_prefix=(exec)
  local -a exec_only_args=()
  local -a prefix_args=()
  local i=0

  [ "${#args[@]}" -gt 0 ] || return 0
  if [ "${args[0]}" = "exec" ]; then
    printf '%s\0' "${args[@]}"
    return
  fi

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --json|--ephemeral)
        exec_only_args+=("${args[$i]}")
        i=$((i + 1))
        ;;
      -o|--output-last-message|--color|--output-schema)
        exec_only_args+=("${args[$i]}")
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          exec_only_args+=("${args[$i]}")
        fi
        i=$((i + 1))
        ;;
      --)
        if [ "${#prefix_args[@]}" -gt 0 ]; then
          printf '%s\0' "${prefix_args[@]}"
        fi
        printf '%s\0' "${exec_prefix[@]}"
        if [ "${#exec_only_args[@]}" -gt 0 ]; then
          printf '%s\0' "${exec_only_args[@]}"
        fi
        printf '%s\0' "${args[@]:${i}}"
        return
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir|--remote|--remote-auth-token-env)
        prefix_args+=("${args[$i]}")
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          prefix_args+=("${args[$i]}")
        fi
        i=$((i + 1))
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|-h|--help|-V|--version)
        prefix_args+=("${args[$i]}")
        i=$((i + 1))
        ;;
      -*)
        prefix_args+=("${args[$i]}")
        i=$((i + 1))
        ;;
      *)
        if is_codex_subcommand "${args[$i]}"; then
          printf '%s\0' "${args[@]}"
          return
        fi
        if [ "${#prefix_args[@]}" -gt 0 ]; then
          printf '%s\0' "${prefix_args[@]}"
        fi
        printf '%s\0' "${exec_prefix[@]}"
        if [ "${#exec_only_args[@]}" -gt 0 ]; then
          printf '%s\0' "${exec_only_args[@]}"
        fi
        printf '%s\0' "${args[@]:${i}}"
        return
        ;;
    esac
  done

  if [ "${#prefix_args[@]}" -gt 0 ]; then
    printf '%s\0' "${prefix_args[@]}"
  fi
  printf '%s\0' "${exec_prefix[@]}"
  if [ "${#exec_only_args[@]}" -gt 0 ]; then
    printf '%s\0' "${exec_only_args[@]}"
  fi
}

iso_in_seconds() {
  local seconds="${1:-0}"
  "${PROXY_PYTHON}" - "${seconds}" <<'PY'
import datetime as dt
import sys

try:
    seconds = max(0, int(float(sys.argv[1] or "0")))
except ValueError:
    seconds = 0
now = dt.datetime.now(dt.timezone.utc) + dt.timedelta(seconds=seconds)
print(now.replace(microsecond=0).isoformat().replace("+00:00", "Z"))
PY
}

