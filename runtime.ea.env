# Non-secret defaults for wiring EA into Fleet via the local MCP bridge.
# Override any of these in the ignored `runtime.env` if needed.
EA_MCP_BASE_URL=http://host.docker.internal:8090
EA_MCP_API_TOKEN=
EA_MCP_PRINCIPAL_ID=codex-fleet
EA_MCP_TIMEOUT_SECONDS=120
EA_MCP_MODEL=gemini-3-flash-preview

