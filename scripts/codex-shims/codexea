def _load_status_payload() -> dict[str, object]:
    try:
        completed = subprocess.run(
            STATUS_COMMAND,
            capture_output=True,
            text=True,
            timeout=20,
            check=False,
        )
        if completed.returncode == 0:
            payload = json.loads(completed.stdout)
            if isinstance(payload, dict):
                return payload
    except Exception:
        pass
    try:
        payload = json.loads(STATE_PATH.read_text(encoding="utf-8"))
        if isinstance(payload, dict):
            return payload
    except Exception:
        pass
    return {}


def _dedupe(items: list[str]) -> list[str]:
    seen: set[str] = set()
    result: list[str] = []
    for item in items:
        cleaned = str(item or "").strip()
        if not cleaned or cleaned in seen:
            continue
        seen.add(cleaned)
        result.append(cleaned)
    return result


def _trim_command_output(value: str, *, max_lines: int = 10, max_chars: int = 1600) -> str:
    lines = str(value or "").splitlines()
    if len(lines) > max_lines:
        lines = lines[:max_lines] + [f"... output truncated to {max_lines} lines"]
    compact = "\n".join(lines).strip()
    if len(compact) > max_chars:
        compact = compact[: max_chars - 32].rstrip() + "\n... output truncated"
    return compact


def _read_trimmed_file(path: Path | None, *, max_lines: int, max_chars: int) -> str:
    if path is None:
        return ""
    try:
        return _trim_command_output(path.read_text(encoding="utf-8"), max_lines=max_lines, max_chars=max_chars)
    except Exception:
        return ""


def _latest_matching_path(pattern: str) -> Path | None:
    latest_path: Path | None = None
    latest_mtime = -1.0
    try:
        for candidate in STATE_ROOT.glob(pattern):
            if not candidate.is_file():
                continue
            try:
                mtime = float(candidate.stat().st_mtime)
            except Exception:
                continue
            if mtime > latest_mtime:
                latest_mtime = mtime
                latest_path = candidate
    except Exception:
        return None
    return latest_path


def _latest_matching_paths(pattern: str, *, limit: int = 8) -> list[Path]:
    ranked_paths: list[tuple[float, Path]] = []
    try:
        for candidate in STATE_ROOT.glob(pattern):
            if not candidate.is_file():
                continue
            try:
                mtime = float(candidate.stat().st_mtime)
            except Exception:
                continue
            ranked_paths.append((mtime, candidate))
    except Exception:
        return []
    ranked_paths.sort(key=lambda item: item[0], reverse=True)
    return [candidate for _, candidate in ranked_paths[: max(1, int(limit or 0))]]


def _non_trace_lines(text: str) -> list[str]:
    result: list[str] = []
    for raw_line in str(text or "").splitlines():
        line = str(raw_line or "").strip()
        if not line:
            continue
        if line.lower().startswith("trace:"):
            continue
        result.append(line)
    return result


def _first_matching_line(text: str, needles: tuple[str, ...]) -> str:
    lowered_needles = tuple(str(item or "").lower() for item in needles if str(item or "").strip())
    lines = _non_trace_lines(text) or [str(raw_line or "").strip() for raw_line in str(text or "").splitlines() if str(raw_line or "").strip()]
    for line in lines:
        lowered = line.lower()
        if any(needle in lowered for needle in lowered_needles):
            return line
    return ""


def _compact_worker_stderr_excerpt(path: Path | None) -> str:
    if path is None:
        return ""
    try:
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return ""
    out: list[str] = []
    primary_blocker_needles = (
        "provider-health preflight left no routable direct lanes",
        "no runnable full routed accounts",
        "upstream_unavailable",
        "onemin_no_eligible_account",
    )
    fallback_blocker_needles = (
        "attempt ",
    )
    stage_needle = "Safe first commands if you need orientation"
    blocker_index = next(
        (
            index
            for index, raw_line in enumerate(lines)
            if str(raw_line or "").strip()
            and any(needle in str(raw_line or "").lower() for needle in primary_blocker_needles)
        ),
        None,
    )
    if blocker_index is None:
        blocker_index = next(
            (
                index
                for index, raw_line in enumerate(lines)
                if str(raw_line or "").strip()
                and any(needle in str(raw_line or "").lower() for needle in fallback_blocker_needles)
            ),
            None,
        )
    if blocker_index is not None:
        out.extend(lines[max(0, blocker_index - 2) : min(len(lines), blocker_index + 3)])
    stage_index = next(
        (
            index
            for index, raw_line in enumerate(lines)
            if stage_needle.lower() in str(raw_line or "").lower()
        ),
        None,
    )
    if stage_index is not None:
        if out:
            out.append("")
        out.extend(lines[stage_index : min(len(lines), stage_index + 20)])
    if not out:
        out = lines[:18]
    return _trim_command_output("\n".join(out), max_lines=24, max_chars=2600)


