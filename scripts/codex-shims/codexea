          normalized_status_loop_command="${line% in /*}"
          case "${normalized_status_loop_command}" in
            *"python3 /docker/fleet/scripts/chummer_design_supervisor.py status"*|*"python3 /docker/fleet/scripts/chummer_design_supervisor.py eta"*)
              case "${normalized_status_loop_command}" in
                *"remaining_open_milestones"* )
                  case "${normalized_status_loop_command}" in
                    *"eta_human"* )
                      if [ "${normalized_status_loop_command}" = "${last_status_loop_command}" ]; then
                        status_loop_hits=$((status_loop_hits + 1))
                      else
                        last_status_loop_command="${normalized_status_loop_command}"
                        status_loop_hits=1
                      fi
                      if [ "${status_loop_hits}" -ge 2 ] && [ ! -s "${monitor_reason_file}" ]; then
                        printf '%s\n' "supervisor_status_loop_stderr" > "${monitor_reason_file}"
                      fi
                      ;;
                  esac
                  ;;
              esac
              ;;
          esac
        done
      ) &
    else
      stdin_file="$(mktemp)"
      if [ -n "${CODEXEA_STDIN_PROMPT-}" ]; then
        printf '%s' "${CODEXEA_STDIN_PROMPT}" > "${stdin_file}"
      else
        : > "${stdin_file}"
      fi
      "${json_cmd[@]}" < "${stdin_file}" > "${fifo_path}" 2> >(
        last_status_loop_command=""
        status_loop_hits=0
        while IFS= read -r line; do
          printf '%s\n' "${line}" >> "${attempt_log}"
          if [ "${line}" != "Reading additional input from stdin..." ]; then
            printf '%s\n' "${line}" >&2
          fi
          normalized_status_loop_command="${line% in /*}"
          case "${normalized_status_loop_command}" in
            *"python3 /docker/fleet/scripts/chummer_design_supervisor.py status"*|*"python3 /docker/fleet/scripts/chummer_design_supervisor.py eta"*)
              case "${normalized_status_loop_command}" in
                *"remaining_open_milestones"* )
                  case "${normalized_status_loop_command}" in
                    *"eta_human"* )
                      if [ "${normalized_status_loop_command}" = "${last_status_loop_command}" ]; then
                        status_loop_hits=$((status_loop_hits + 1))
                      else
                        last_status_loop_command="${normalized_status_loop_command}"
                        status_loop_hits=1
                      fi
                      if [ "${status_loop_hits}" -ge 2 ] && [ ! -s "${monitor_reason_file}" ]; then
                        printf '%s\n' "supervisor_status_loop_stderr" > "${monitor_reason_file}"
                      fi
                      ;;
                  esac
                  ;;
              esac
              ;;
          esac
        done
      ) &
    fi
    child_pid=$!
    trap 'interrupted_exit=130; kill -INT "${child_pid}" 2>/dev/null || true' INT
    trap 'interrupted_exit=143; kill -TERM "${child_pid}" 2>/dev/null || true' TERM

    while kill -0 "${child_pid}" 2>/dev/null; do
      sleep 0.1 || break
      kill -0 "${child_pid}" 2>/dev/null || break
      tick_count=$((tick_count + 1))
      if [ "${tick_count}" -ge 100 ]; then
        elapsed_seconds="$(( $(date +%s) - heartbeat_started_at ))"
        emit_waiting_trace "${elapsed_seconds}"
        tick_count=0
      fi
      elapsed_seconds="$(( $(date +%s) - heartbeat_started_at ))"
      if [ -s "${monitor_reason_file}" ]; then
        monitor_reason="$(head -n 1 "${monitor_reason_file}" | tr -d '\r\n')"
        if [ -n "${monitor_reason}" ]; then
          printf 'Trace: lane=%s terminating exec after monitor reason=%s\n' "${EFFECTIVE_LANE}" "${monitor_reason}" >&2
          kill -TERM "${child_pid}" 2>/dev/null || true
          sleep 1
          kill -KILL "${child_pid}" 2>/dev/null || true
          child_exit=125
          break
        fi
      fi
      if [ "${hard_timeout_seconds}" -gt 0 ] && [ "${elapsed_seconds}" -ge "${hard_timeout_seconds}" ]; then
        printf 'Trace: lane=%s terminating stalled exec after %ss\n' "${EFFECTIVE_LANE}" "${elapsed_seconds}" >&2
        kill -TERM "${child_pid}" 2>/dev/null || true
        sleep 1
        kill -KILL "${child_pid}" 2>/dev/null || true
        child_exit=124
        break
      fi
    done

    set +e
    wait "${child_pid}"
    if [ "${child_exit}" -eq 0 ]; then
      child_exit=$?
    else
      wait "${child_pid}" 2>/dev/null || true
    fi
    wait "${renderer_pid}" 2>/dev/null
    set -e
    if [ -n "${stdin_file}" ]; then
      rm -f "${stdin_file}"
    fi
    rm -f "${fifo_path}"
    rm -f "${monitor_reason_file}"

    if ! retryable_transport_failure_log "${attempt_log}" "${child_exit}" "${output_last_message_path}"; then
      rm -f "${attempt_log}"
      break
    fi
    if [ "$(date +%s)" -ge "${retry_deadline}" ]; then
      printf 'Trace: lane=%s clean-exec retry window exhausted after attempt=%s exit=%s\n' "${EFFECTIVE_LANE}" "${retry_attempt}" "${child_exit}" >&2
      rm -f "${attempt_log}"
      break
    fi
    printf 'Trace: lane=%s retrying clean-exec transport failure in %ss (attempt=%s exit=%s)\n' "${EFFECTIVE_LANE}" "${retry_sleep_seconds}" "${retry_attempt}" "${child_exit}" >&2
    rm -f "${attempt_log}"
    sleep "${retry_sleep_seconds}"
  done

  trap - INT TERM

  if [ "${interrupted_exit}" -ne 0 ]; then
    return "${interrupted_exit}"
  fi
  return "${child_exit}"
}

emit_startup_trace() {
  local next_step="$1"
  local provider_label="unknown"
  local trace_model="${MODEL:-}"
  local trace_suffix=""
  env_truthy "${CODEXEA_TRACE_STARTUP}" || return 0
  case "${MODE:-}" in
    responses)
      provider_label="ea"
      ;;
    mcp)
      provider_label="mcp"
      if [ -z "${trace_model}" ]; then
        trace_model="default-config"
        if [ -n "${EA_MCP_MODEL:-}" ]; then
          trace_suffix=" mcp_model=${EA_MCP_MODEL}"
        fi
      fi
      ;;
  esac
  printf 'Trace: lane=%s provider=%s model=%s mode=%s%s next=%s\n' \
    "${EFFECTIVE_LANE}" \
    "${provider_label}" \
    "${trace_model}" \
    "${MODE}" \
    "${trace_suffix}" \
    "${next_step}" >&2
}

emit_prelaunch_wait_trace() {
  local trace_lane="${REQUESTED_LANE:-${CODEXEA_DEFAULT_LANE:-easy}}"
  local mode="${1:-wait}"
  env_truthy "${CODEXEA_TRACE_STARTUP}" || return 0
  [ -t 1 ] || return 0
  case "${mode}" in
    task)
      printf 'Trace: lane=%s starting interactive session with initial task\n' \
        "${trace_lane}" >&2
      ;;
    *)
      printf 'Trace: lane=%s ready and waiting for user instructions\n' \
        "${trace_lane}" >&2
      ;;
  esac
}

emit_waiting_trace() {
  local elapsed_seconds="${1:-0}"
  env_truthy "${CODEXEA_TRACE_STARTUP}" || return 0
  printf 'Trace: lane=%s waiting for upstream response (total_duration=%ss)\n' "${EFFECTIVE_LANE}" "${elapsed_seconds}" >&2
}

operator_guard_transport_retry_enabled() {
  env_truthy "${CODEXEA_OPERATOR_GUARD_ACTIVE:-0}" || return 1
  env_truthy "${CODEXEA_OPERATOR_GUARD_TRANSPORT_RETRY:-1}"
}

retryable_transport_failure_log() {
  local log_path="${1:-}"
  local exit_code="${2:-0}"
  local output_last_message_path="${3:-}"
  [ -n "${log_path}" ] || return 1
  [ -f "${log_path}" ] || return 1
  grep -Eiq \
    'stream disconnected before completion|transport=reconnecting|transport=recovered|error sending request for url \((http://127\.0\.0\.1:8090|http://host\.docker\.internal:8090)/v1/responses\)|unexpected status 502 bad gateway|proxy_upstream_failure|the read operation timed out' \
    "${log_path}" || return 1
  case "${exit_code}" in
    130|143)
      return 1
      ;;
  esac
  if [ "${exit_code}" -ne 0 ]; then
    return 0
  fi
  [ -n "${output_last_message_path}" ] || return 1
  [ -f "${output_last_message_path}" ] || return 0
  [ -s "${output_last_message_path}" ] || return 0
  return 1
}

extract_output_last_message_path() {
  local -a args=("$@")
  local i=0

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      -o|--output-last-message)
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          printf '%s' "${args[$i]}"
          return 0
        fi
        break
        ;;
    esac
    i=$((i + 1))
  done
  return 1
}

run_with_trace_heartbeat() {
  local interval="${CODEXEA_TRACE_HEARTBEAT_SECONDS:-2}"
  local -a cmd=("$@")
  local -a effective_cmd=("${cmd[@]}")
  local script_cmd_line=""
  local child_pid=0
  local interrupted_exit=0
  local exit_code=0
  local interval_seconds
  local elapsed_seconds=0
  local heartbeat_started_at=0
  local tracer_pid=0
  local stdin_file=""
  local script_trace_log=""
  local child_exit=0
  local hard_timeout_seconds=0
  local retry_sleep_seconds=0
  local retry_window_seconds=0
  local retry_deadline=0
  local retry_attempt=0
  local attempt_log=""
  local -a run_cmd=()

  [ "${#cmd[@]}" -gt 0 ] || return 0
  env_truthy "${CODEXEA_TRACE_STARTUP}" || {
    "${effective_cmd[@]}"
    return $?
  }
  case "${interval}" in
    ""|0|0.0)
      "${effective_cmd[@]}"
      return $?
      ;;
  esac
  interval_seconds="$(python3 - "${interval}" <<'PY'
import sys

try:
    interval = float(sys.argv[1] or "5")
except ValueError:
    interval = 5.0
if interval <= 0:
    interval = 5.0
print(interval)
PY
  )"
  hard_timeout_seconds="$(positive_integer_or_default "${CODEXEA_EXEC_HARD_TIMEOUT_SECONDS:-0}" "3600")"

  if [ "${CODEXEA_DISABLE_SCRIPT_WRAPPER:-0}" != "1" ] && [ "${INTERACTIVE_SESSION_REQUEST:-0}" -eq 1 ] && [ "${CODEXEA_SCRIPT_WRAPPED:-0}" != "1" ] && { [ -n "${TMUX-}" ] || [ ! -t 0 ] || [ ! -t 1 ]; }; then
    if script_supports_tty_wrapper; then
      script_trace_log="${CODEXEA_STATE_DIR}/codexea-script-$$-${RANDOM}.log"
      printf -v script_cmd_line '%q ' "${cmd[@]}"
      if [ -n "${script_cmd_line}" ]; then
        script_cmd_line="${script_cmd_line% }"
        case "${SCRIPT_TTY_WRAPPER_STYLE:-}" in
          long)
            effective_cmd=(env CODEXEA_SCRIPT_WRAPPED=1 script --quiet --return --command "${script_cmd_line}" "${script_trace_log}")
            ;;
          short)
            effective_cmd=(env CODEXEA_SCRIPT_WRAPPED=1 script -q -c "${script_cmd_line}" "${script_trace_log}")
            ;;
        esac
      fi
    fi
  fi

  if [ ! -t 0 ] || [ ! -t 1 ]; then
    stdin_file="$(mktemp)"
    if [ -n "${CODEXEA_STDIN_PROMPT-}" ]; then
      printf '%s' "${CODEXEA_STDIN_PROMPT}" > "${stdin_file}"
    else
      : > "${stdin_file}"
    fi
    heartbeat_started_at="$(date +%s)"
    emit_waiting_trace 0
    "${effective_cmd[@]}" < "${stdin_file}" &
    child_pid=$!
    trap 'interrupted_exit=130; kill -INT "${child_pid}" 2>/dev/null || true' INT
    trap 'interrupted_exit=143; kill -TERM "${child_pid}" 2>/dev/null || true' TERM

    while kill -0 "${child_pid}" 2>/dev/null; do
      sleep 0.1 || break
      kill -0 "${child_pid}" 2>/dev/null || break
      exit_code=$((exit_code + 1))
      if [ "${exit_code}" -ge 250 ]; then
        elapsed_seconds="$(( $(date +%s) - heartbeat_started_at ))"
        emit_waiting_trace "${elapsed_seconds}"
        exit_code=0
      fi
      elapsed_seconds="$(( $(date +%s) - heartbeat_started_at ))"
      if [ "${hard_timeout_seconds}" -gt 0 ] && [ "${elapsed_seconds}" -ge "${hard_timeout_seconds}" ]; then
        printf 'Trace: lane=%s terminating stalled session after %ss\n' "${EFFECTIVE_LANE}" "${elapsed_seconds}" >&2
        kill -TERM "${child_pid}" 2>/dev/null || true
        sleep 1
        kill -KILL "${child_pid}" 2>/dev/null || true
        child_exit=124
        break
      fi
    done

    set +e
    wait "${child_pid}"
    if [ "${child_exit}" -eq 0 ]; then
      child_exit=$?
    else
      wait "${child_pid}" 2>/dev/null || true
    fi
    set -e
    trap - INT TERM
    rm -f "${stdin_file}"
    if [ "${interrupted_exit}" -ne 0 ]; then
      return "${interrupted_exit}"
    fi
    return "${child_exit}"
  fi

  (
    emit_waiting_trace 0
    heartbeat_started_at="$(date +%s)"
    while true; do
      sleep "${interval_seconds}" || break
      elapsed_seconds="$(( $(date +%s) - heartbeat_started_at ))"
      emit_waiting_trace "${elapsed_seconds}"
    done
  ) &
  tracer_pid=$!

  retry_sleep_seconds="$(positive_integer_or_default "${CODEXEA_OPERATOR_GUARD_TRANSPORT_RETRY_SLEEP_SECONDS:-10}" "10")"
  retry_window_seconds="$(positive_integer_or_default "${CODEXEA_OPERATOR_GUARD_TRANSPORT_RETRY_WINDOW_SECONDS:-86400}" "86400")"
  retry_deadline="$(( $(date +%s) + retry_window_seconds ))"

  while true; do
    retry_attempt=$((retry_attempt + 1))
    attempt_log=""
    run_cmd=("${effective_cmd[@]}")
    if operator_guard_transport_retry_enabled && script_supports_tty_wrapper && [ "${SCRIPT_TTY_WRAPPER_STYLE:-}" = "long" ]; then
      attempt_log="${CODEXEA_STATE_DIR}/transport-retry-attempt-${retry_attempt}.log"
      printf -v script_cmd_line '%q ' "${effective_cmd[@]}"
      script_cmd_line="${script_cmd_line% }"
      run_cmd=(env CODEXEA_SCRIPT_WRAPPED=1 script --quiet --return --command "${script_cmd_line}" "${attempt_log}")
    fi

    set +e
    "${run_cmd[@]}"
    child_exit=$?
    set -e

    if ! retryable_transport_failure_log "${attempt_log}" "${child_exit}"; then
      break
    fi
    if [ "$(date +%s)" -ge "${retry_deadline}" ]; then
      printf 'Trace: lane=%s transport retry window exhausted after attempt=%s exit=%s\n' "${EFFECTIVE_LANE}" "${retry_attempt}" "${child_exit}" >&2
      break
    fi
    printf 'Trace: lane=%s retrying transient transport failure in %ss (attempt=%s exit=%s)\n' "${EFFECTIVE_LANE}" "${retry_sleep_seconds}" "${retry_attempt}" "${child_exit}" >&2
    sleep "${retry_sleep_seconds}"
  done

  if [ "${tracer_pid}" -ne 0 ]; then
    kill "${tracer_pid}" 2>/dev/null || true
    wait "${tracer_pid}" 2>/dev/null || true
  fi
  if [ -n "${script_trace_log}" ]; then
    rm -f "${script_trace_log}" || true
  fi

  return "${child_exit}"
}

append_query_param() {
  local url="$1"
  local name="$2"
  local value="$3"

  if printf '%s' "${url}" | grep -q "?" ; then
    printf '%s&%s=%s' "${url}" "${name}" "${value}"
  else
    printf '%s?%s=%s' "${url}" "${name}" "${value}"
  fi
}

interactive_route_lane() {
  local output=""
  local key=""
  local value=""
  local lane=""

  [ -f "${ROUTE_HELPER}" ] || return 1
  output="$(python3 "${ROUTE_HELPER}" "$@" 2>/dev/null)" || return 1
  while IFS='=' read -r key value; do
    case "${key}" in
      lane)
        lane="${value}"
        ;;
    esac
  done <<< "${output}"
  [ -n "${lane}" ] || return 1
  printf '%s' "${lane}"
}

capture_post_audit_context() {
  local git_root=""

  if ! command -v git >/dev/null 2>&1; then
    return 1
  fi
  if ! git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    return 1
  fi
  CODEXEA_POST_AUDIT_GIT_ROOT="${git_root}"
  CODEXEA_POST_AUDIT_START_HEAD="$(git -C "${git_root}" rev-parse HEAD 2>/dev/null || true)"
  export CODEXEA_POST_AUDIT_GIT_ROOT
  export CODEXEA_POST_AUDIT_START_HEAD
  return 0
}

build_post_audit_request() {
  local target="$1"
  python3 - "${target}" <<'PY'
import json
import os
import subprocess
import sys
from pathlib import Path


target = Path(sys.argv[1])
root = os.environ.get("CODEXEA_POST_AUDIT_GIT_ROOT", "").strip()
start_head = os.environ.get("CODEXEA_POST_AUDIT_START_HEAD", "").strip()
model = os.environ.get("CODEXEA_POST_AUDIT_MODEL", "ea-review-light").strip() or "ea-review-light"
lane = os.environ.get("CODEXEA_LANE", "").strip()
submode = os.environ.get("CODEXEA_SUBMODE", "").strip()
objective = os.environ.get("CODEXEA_POST_AUDIT_OBJECTIVE", "").strip()
cwd = os.environ.get("PWD", "").strip()
only_on_diff = str(os.environ.get("CODEXEA_POST_AUDIT_ONLY_ON_DIFF", "1")).strip().lower() in {"1", "true", "yes", "on"}
only_on_verify = str(os.environ.get("CODEXEA_POST_AUDIT_ONLY_ON_VERIFY", "0")).strip().lower() in {"1", "true", "yes", "on"}
try:
    exit_code = int(str(os.environ.get("CODEXEA_POST_AUDIT_EXIT_CODE", "0") or "0"))
except Exception:
    exit_code = 0

if not root:
    raise SystemExit(2)


def run_git(*args: str) -> str:
    try:
        completed = subprocess.run(
            ["git", "-C", root, *args],
            capture_output=True,
            text=True,
            check=False,
        )
    except Exception:
        return ""
    return completed.stdout.strip()


end_head = run_git("rev-parse", "HEAD")
changed_files: list[str] = []
seen: set[str] = set()


def add_files(raw: str) -> None:
    for line in raw.splitlines():
        cleaned = line.strip()
        if not cleaned:
            continue
        if " -> " in cleaned:
            cleaned = cleaned.split(" -> ", 1)[1].strip()
        if cleaned in seen:
            continue
        seen.add(cleaned)
        changed_files.append(cleaned)


commit_range = ""
if start_head and end_head and start_head != end_head:
    commit_range = f"{start_head}..{end_head}"
    add_files(run_git("diff", "--name-only", commit_range, "--"))

add_files(run_git("diff", "--name-only", "--"))
add_files(run_git("diff", "--cached", "--name-only", "--"))
add_files(run_git("ls-files", "--others", "--exclude-standard"))

if only_on_diff and not changed_files:
    raise SystemExit(2)
if only_on_verify:
    raise SystemExit(2)

verification = {
    "commands": [],
    "passed": None,
    "session_exit_code": exit_code,
    "notes": ["No verification commands were captured by the codexea shim."],
}

diff_sections: list[str] = []
if commit_range:
    committed = run_git("diff", "--stat", "--compact-summary", commit_range, "--")
    if committed:
        diff_sections.append(f"Committed since session start ({commit_range}):\n{committed}")
unstaged = run_git("diff", "--stat", "--compact-summary", "--")
if unstaged:
    diff_sections.append(f"Unstaged worktree diff:\n{unstaged}")
staged = run_git("diff", "--cached", "--stat", "--compact-summary", "--")
if staged:
    diff_sections.append(f"Staged worktree diff:\n{staged}")
untracked = run_git("ls-files", "--others", "--exclude-standard")
if untracked:
    diff_sections.append(
        "Untracked files:\n" + "\n".join(f"- {line.strip()}" for line in untracked.splitlines() if line.strip())
    )
diff_summary = "\n\n".join(section for section in diff_sections if section).strip()
if len(diff_summary) > 4000:
    diff_summary = diff_summary[:3997].rstrip() + "..."

if not objective:
    objective = f"Interactive CodexEA slice in {cwd or root}"

warnings = ["no_verification_captured_by_shim", "review_packet_derived_from_git_state"]
if exit_code != 0:
    warnings.append(f"session_exit_nonzero:{exit_code}")
if not changed_files:
    warnings.append("no_git_delta_detected")

final_claim = (
    f"CodexEA lane={lane or 'unknown'} submode={submode or 'unknown'} exited with code {exit_code} "
    f"and produced the reported git delta."
)

packet = {
    "objective": objective,
    "changed_files": changed_files,
    "diff_summary": diff_summary,
    "verification": verification,
    "warnings": warnings,
    "final_claim": final_claim,
}
review_prompt = (
    "Perform a light post-hoc review of this completed coding slice. "
    "Use only the compact packet. Focus on obvious factual errors, risky claims, missing verification, "
    "and likely regressions. Keep the output concise.\n\n"
    + json.dumps(packet, ensure_ascii=True, indent=2)
)
request_payload = {
    "model": model,
    "input": review_prompt,
    "metadata": {
        "codexea_post_audit": True,
        "codexea_lane": lane,
        "codexea_submode": submode,
        "codexea_git_root": root,
        "codexea_review_packet": packet,
    },
}
target.write_text(json.dumps(request_payload, ensure_ascii=True), encoding="utf-8")
PY
}

emit_post_audit_request() {
  local review_file="$1"
  local token="${EA_MCP_API_TOKEN:-${EA_API_TOKEN:-}}"
  local -a curl_args=(curl -fsS -H "X-EA-Principal-ID: ${EA_PRINCIPAL_ID:-archon-codex-ea}" -H "Content-Type: application/json")
  local auth_config=""

  env_truthy "${CODEXEA_POST_AUDIT}" || return 0
  [ -f "${review_file}" ] || return 0
  command -v curl >/dev/null 2>&1 || return 0
  auth_config="$(build_ea_curl_auth_config "${token}" || true)"
  if [ -n "${auth_config}" ]; then
    curl_args+=(-K "${auth_config}")
  fi
  curl_args+=(-d @"${review_file}" "${EA_BASE_URL%/}/v1/codex/review-light")
  if env_truthy "${CODEXEA_POST_AUDIT_ASYNC}"; then
    (
      nohup "${curl_args[@]}" >/dev/null 2>&1
      cleanup_ea_curl_auth_config "${auth_config}"
    ) >/dev/null 2>&1 &
  else
    "${curl_args[@]}" >/dev/null 2>&1 || true
    cleanup_ea_curl_auth_config "${auth_config}"
  fi
}

escape_curl_config_value() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "${value}"
}

build_ea_curl_auth_config() {
  local token="${1:-}"
  local config_path=""
  local escaped_token=""

  [ -n "${token}" ] || return 1
  config_path="$(mktemp "${TMPDIR:-/tmp}/codexea-curl-auth.XXXXXX")"
  chmod 600 "${config_path}" || true
  escaped_token="$(escape_curl_config_value "${token}")"
  {
    printf 'header = "Authorization: Bearer %s"\n' "${escaped_token}"
    printf 'header = "X-EA-Api-Token: %s"\n' "${escaped_token}"
    printf 'header = "X-API-Token: %s"\n' "${escaped_token}"
  } > "${config_path}"
  printf '%s' "${config_path}"
}

cleanup_ea_curl_auth_config() {
  local config_path="${1:-}"
  [ -n "${config_path}" ] || return 0
  rm -f "${config_path}"
}

show_status() {
  local want_json=0
  local refresh=0
  local startup_compact=0
  local watch_seconds=""
  local window="1h"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json)
        want_json=1
        ;;
      --startup)
        startup_compact=1
        ;;
      --refresh)
        refresh=1
        ;;
      --watch)
        shift
        watch_seconds="${1:-30}"
        ;;
      --window)
        shift
        window="${1:-1h}"
        ;;
      *)
        echo "Unknown status flag: $1" >&2
        return 2
        ;;
    esac
    shift || true
  done
  local -a curl_args=(
    curl
    -fsS
