UNSUPPORTED_INPUT_RETRY_PROMPT=""
UNSUPPORTED_INPUT_RETRY_CMD=()

build_exec_stdin_retry_command() {
  local -a args=("$@")
  local -a prefix_args=()
  local -a exec_only_args=()
  local -a prompt_args=()
  local i=0
  local saw_exec=0
  local arg=""

  UNSUPPORTED_INPUT_RETRY_PROMPT=""
  UNSUPPORTED_INPUT_RETRY_CMD=()

  while [ "${i}" -lt "${#args[@]}" ]; do
    arg="${args[$i]}"
    if [ "${saw_exec}" -eq 0 ]; then
      prefix_args+=("${arg}")
      if [ "${arg}" = "exec" ]; then
        saw_exec=1
      fi
      i=$((i + 1))
      continue
    fi

    case "${arg}" in
      --json|--ephemeral)
        exec_only_args+=("${arg}")
        i=$((i + 1))
        ;;
      -o|--output-last-message|--color|--output-schema)
        exec_only_args+=("${arg}")
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          exec_only_args+=("${args[$i]}")
        fi
        i=$((i + 1))
        ;;
      --)
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          prompt_args=("${args[@]:${i}}")
        fi
        i="${#args[@]}"
        ;;
      -)
        return 1
        ;;
      *)
        prompt_args=("${args[@]:${i}}")
        i="${#args[@]}"
        ;;
    esac
  done

  [ "${saw_exec}" -eq 1 ] || return 1
  [ "${#prompt_args[@]}" -gt 0 ] || return 1
  UNSUPPORTED_INPUT_RETRY_PROMPT="${prompt_args[*]}"
  UNSUPPORTED_INPUT_RETRY_CMD=("${prefix_args[@]}" "${exec_only_args[@]}" -)
  return 0
}

emit_unsupported_input_retry_trace() {
  printf 'Trace: provider=%s compat=unsupported_input_item retry=stdin_exec\n' "${CODEXLIZ_PROVIDER_KEY}" >&2
}

classify_transport_failure() {
  local stderr_path="${1:-}"
  local output_path="${2:-}"
  local require_empty="${3:-1}"
  local local_provider_base_url="${4:-}"
  local upstream_base_url="${5:-}"

  "${PROXY_PYTHON}" - "${stderr_path}" "${output_path}" "${require_empty}" "${local_provider_base_url}" "${upstream_base_url}" <<'PY'
import re
import sys
from pathlib import Path

stderr_path = Path(sys.argv[1])
output_path = Path(sys.argv[2]) if sys.argv[2] else None
require_empty = str(sys.argv[3] or "1").strip().lower() in {"1", "true", "yes", "on"}
local_provider_base_url = str(sys.argv[4] or "").strip()
upstream_base_url = str(sys.argv[5] or "").strip()
stderr_text = stderr_path.read_text(encoding="utf-8", errors="replace") if stderr_path.exists() else ""
output_empty = True
if output_path and output_path.exists():
    try:
        output_empty = not output_path.read_text(encoding="utf-8", errors="replace").strip()
    except OSError:
        output_empty = True

status_matches = re.findall(r"unexpected status (\d{3})", stderr_text)
if not status_matches:
    status_matches = re.findall(r"returned HTTP (\d{3})", stderr_text)
http_status = int(status_matches[-1]) if status_matches else None
cf_matches = re.findall(r"cf-ray:\s*([A-Za-z0-9-]+)", stderr_text, flags=re.I)
cf_ray = cf_matches[-1] if cf_matches else ""
retryable_codes = {404, 429, 500, 502, 503, 504, 520, 522, 523, 524}
reason = ""
detail = ""
retryable = False
lowered = stderr_text.lower()
transport_hint = any(hint and hint in stderr_text for hint in (local_provider_base_url, upstream_base_url))
if "proxy_upstream_failure" in lowered:
    retryable = True
    reason = "proxy_upstream_failure"
elif http_status in retryable_codes and (transport_hint or "cf-ray:" in lowered or "bad gateway" in lowered):
    retryable = True
    reason = f"http_{http_status}"
elif "read operation timed out" in lowered or "timed out" in lowered:
    retryable = True
    reason = "transport_timeout"
elif "reconnecting... 5/5" in lowered and (transport_hint or "cf-ray:" in lowered):
    retryable = True
    reason = "retries_exhausted"

if require_empty and not output_empty:
    retryable = False
    reason = "output_already_present"

if http_status is not None:
    detail = f"HTTP {http_status}"
elif reason == "transport_timeout":
    detail = "timed out"
elif reason == "proxy_upstream_failure":
    detail = "proxy upstream failure"
elif reason == "retries_exhausted":
    detail = "retries exhausted"

print(f"retryable={'1' if retryable else '0'}")
print(f"http_status={http_status or ''}")
print(f"cf_ray={cf_ray}")
print(f"reason={reason}")
print(f"detail={detail}")
print(f"output_empty={'1' if output_empty else '0'}")
PY
}

write_transport_state() {
  local state="${1:-unknown}"
  local current_outage="${2:-0}"
  local http_status="${3:-}"
  local cf_ray="${4:-}"
  local reason="${5:-}"
  local detail="${6:-}"
  local retry_count="${7:-0}"
  local outage_seconds="${8:-0}"
  local next_retry_at="${9:-}"

  mkdir -p "${CODEXLIZ_STATE_DIR}"
  "${PROXY_PYTHON}" - "${CODEXLIZ_OUTAGE_STATE_FILE}" "${state}" "${current_outage}" "${http_status}" "${cf_ray}" "${reason}" "${detail}" "${retry_count}" "${outage_seconds}" "${next_retry_at}" "${CODEXLIZ_PROXY_PORT}" "${LOCAL_PROVIDER_BASE_URL:-}" "${REMOTE_UPSTREAM_BASE_URL:-}" "${CODEXLIZ_MODEL}" <<'PY'
import datetime as dt
import json
import sys
from pathlib import Path

(
    path_text,
    state,
    current_outage_flag,
    http_status,
    cf_ray,
    reason,
    detail,
    retry_count,
    outage_seconds,
    next_retry_at,
    proxy_port,
    local_provider_base_url,
    upstream_base_url,
    model,
) = sys.argv[1:15]

path = Path(path_text)
try:
    existing = json.loads(path.read_text(encoding="utf-8")) if path.exists() else {}
except Exception:
    existing = {}
payload = existing if isinstance(existing, dict) else {}
now = dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")
current_outage = str(current_outage_flag or "0") == "1"
if current_outage and not bool(payload.get("current_outage")):
    payload["outage_started_at"] = now
if not current_outage and bool(payload.get("current_outage")):
    payload["recovered_at"] = now
payload.update(
    {
        "updated_at": now,
        "state": state or "unknown",
        "current_outage": current_outage,
        "last_http_status": int(http_status) if str(http_status).strip().isdigit() else None,
        "last_cf_ray": cf_ray or "",
        "last_reason": reason or "",
        "last_error": detail or "",
        "retry_count": max(0, int(retry_count or 0)),
        "outage_seconds": max(0, int(outage_seconds or 0)),
        "next_retry_at": next_retry_at or "",
        "proxy_port": proxy_port or "",
        "local_provider_base_url": local_provider_base_url or "",
        "upstream_base_url": upstream_base_url or "",
        "model": model or "",
    }
)
if current_outage:
    payload["last_failure_at"] = now
else:
    payload["last_success_at"] = now
path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

sleep_with_transport_trace() {
  local sleep_seconds="${1:-0}"
  local already_waited_seconds="${2:-0}"
  local http_status="${3:-}"
  local trace_interval
  local remaining
  local step

  trace_interval="$(positive_integer_or_default "${CODEXLIZ_TRANSPORT_TRACE_INTERVAL_SECONDS}" "5")"
  remaining="$(positive_integer_or_default "${sleep_seconds}" "0")"
  already_waited_seconds="$(positive_integer_or_default "${already_waited_seconds}" "0")"
  if [ "${remaining}" -le 0 ]; then
    return 0
  fi

  emit_transport_trace "outage status=${http_status:-unknown} retry_in=${remaining}s elapsed=${already_waited_seconds}s"
  while [ "${remaining}" -gt 0 ]; do
    step="${remaining}"
    if [ "${step}" -gt "${trace_interval}" ]; then
      step="${trace_interval}"
    fi
    sleep "${step}"
    remaining=$((remaining - step))
    if [ "${remaining}" -gt 0 ]; then
      emit_transport_trace "outage status=${http_status:-unknown} retry_in=${remaining}s elapsed=$((already_waited_seconds + sleep_seconds - remaining))s"
    fi
  done
}

run_codex_with_transport_retry() {
  local output_path="${1:-}"
  shift
  local -a cmd=("$@")
  local retry_enabled=0
  local require_empty_output=0
  local base_sleep_seconds
  local max_backoff_seconds
  local max_wait_seconds
  local sleep_seconds=0
  local retry_count=0
  local waited_seconds=0
  local stderr_file=""
  local exit_code=0
  local retryable="0"
  local http_status=""
  local cf_ray=""
  local reason=""
  local detail=""
  local output_empty="1"
  local next_retry_at=""
  local classification=""
  local key=""
  local value=""
  local stdin_file=""
  local unsupported_input_retry_attempted=0

  retry_enabled=0
  if env_truthy "${CODEXLIZ_TRANSPORT_RETRY_ENABLED}"; then
    case "${PRIMARY_COMMAND:-}" in
      ""|exec)
        retry_enabled=1
        ;;
    esac
  fi
  require_empty_output=0
  if env_truthy "${CODEXLIZ_TRANSPORT_REQUIRE_EMPTY_OUTPUT_FOR_RETRY}"; then
    require_empty_output=1
  fi
  base_sleep_seconds="$(positive_integer_or_default "${CODEXLIZ_TRANSPORT_RETRY_INTERVAL_SECONDS}" "60")"
  max_backoff_seconds="$(positive_integer_or_default "${CODEXLIZ_TRANSPORT_RETRY_BACKOFF_MAX_SECONDS}" "300")"
  max_wait_seconds="$(positive_integer_or_default "${CODEXLIZ_TRANSPORT_RETRY_MAX_WAIT_SECONDS}" "86400")"
  sleep_seconds="${base_sleep_seconds}"

  while :; do
    stderr_file="$(mktemp "${TMPDIR:-/tmp}/codexliz-stderr.XXXXXX")"
    set +e
    run_codex_child_with_stderr_capture "${stderr_file}" "${stdin_file}" "${cmd[@]}"
    exit_code=$?
    set -e

    if [ "${exit_code}" -eq 0 ]; then
      write_transport_state "healthy" 0 "" "" "success" "" "${retry_count}" "${waited_seconds}" ""
      rm -f "${stdin_file}"
      rm -f "${stderr_file}"
      return 0
    fi

    if [ "${unsupported_input_retry_attempted}" -eq 0 ] && stderr_has_unsupported_input_item "${stderr_file}" && build_exec_stdin_retry_command "${cmd[@]}"; then
      unsupported_input_retry_attempted=1
      stdin_file="$(mktemp "${TMPDIR:-/tmp}/codexliz-stdin.XXXXXX")"
      printf '%s' "${UNSUPPORTED_INPUT_RETRY_PROMPT}" > "${stdin_file}"
      cmd=("${UNSUPPORTED_INPUT_RETRY_CMD[@]}")
      emit_unsupported_input_retry_trace
      rm -f "${stderr_file}"
      continue
    fi

    classification="$(classify_transport_failure "${stderr_file}" "${output_path}" "${require_empty_output}" "${LOCAL_PROVIDER_BASE_URL}" "${REMOTE_UPSTREAM_BASE_URL}")"
    retryable="0"
    http_status=""
    cf_ray=""
    reason=""
    detail=""
    output_empty="1"
    while IFS='=' read -r key value; do
      case "${key}" in
        retryable) retryable="${value}" ;;
        http_status) http_status="${value}" ;;
        cf_ray) cf_ray="${value}" ;;
        reason) reason="${value}" ;;
        detail) detail="${value}" ;;
        output_empty) output_empty="${value}" ;;
      esac
    done <<< "${classification}"

    if [ "${retry_enabled}" -ne 1 ] || [ "${retryable}" != "1" ]; then
      write_transport_state "failure" 0 "${http_status}" "${cf_ray}" "${reason}" "${detail}" "${retry_count}" "${waited_seconds}" ""
      rm -f "${stdin_file}"
      rm -f "${stderr_file}"
      return "${exit_code}"
    fi

    if [ "${waited_seconds}" -ge "${max_wait_seconds}" ]; then
      emit_transport_trace "outage status=${http_status:-unknown} giving_up_after=${waited_seconds}s"
      write_transport_state "outage_timeout" 1 "${http_status}" "${cf_ray}" "${reason}" "${detail}" "${retry_count}" "${waited_seconds}" ""
      rm -f "${stdin_file}"
      rm -f "${stderr_file}"
      return "${exit_code}"
    fi

    retry_count=$((retry_count + 1))
    if [ $((waited_seconds + sleep_seconds)) -gt "${max_wait_seconds}" ]; then
      sleep_seconds=$((max_wait_seconds - waited_seconds))
    fi
    next_retry_at="$(iso_in_seconds "${sleep_seconds}")"
    write_transport_state "outage_waiting" 1 "${http_status}" "${cf_ray}" "${reason}" "${detail}" "${retry_count}" "${waited_seconds}" "${next_retry_at}"
    sleep_with_transport_trace "${sleep_seconds}" "${waited_seconds}" "${http_status}"
    waited_seconds=$((waited_seconds + sleep_seconds))
    start_proxy_if_needed "${REMOTE_UPSTREAM_BASE_URL}" "${CODEXLIZ_PROXY_PORT}"
    if [ "${sleep_seconds}" -lt "${max_backoff_seconds}" ]; then
      sleep_seconds=$((sleep_seconds * 2))
      if [ "${sleep_seconds}" -gt "${max_backoff_seconds}" ]; then
        sleep_seconds="${max_backoff_seconds}"
      fi
    fi
    rm -f "${stderr_file}"
  done
}

run_models_preflight() {
  local target_url="${1:-}"
  local target_label="${2:-transport}"
  local expected_model="${3:-}"
  local api_key_value=""
  local cf_access_client_id="${CODEXLIZ_CF_ACCESS_CLIENT_ID:-}"
  local cf_access_client_secret="${CODEXLIZ_CF_ACCESS_CLIENT_SECRET:-}"

  if [ -n "${CODEXLIZ_API_KEY_ENV_VAR}" ]; then
    api_key_value="${!CODEXLIZ_API_KEY_ENV_VAR:-}"
  fi

  "${PROXY_PYTHON}" - "${target_url}" "${target_label}" "${expected_model}" "${CODEXLIZ_PREFLIGHT_TIMEOUT_SECONDS}" "${api_key_value}" "${cf_access_client_id}" "${cf_access_client_secret}" <<'PY'
import json
import ssl
import sys
import urllib.error
import urllib.request

target_url = sys.argv[1]
target_label = sys.argv[2]
expected_model = sys.argv[3].strip()
timeout_seconds = float(sys.argv[4] or "5")
api_key_value = sys.argv[5]
cf_access_client_id = sys.argv[6].strip()
cf_access_client_secret = sys.argv[7].strip()

request = urllib.request.Request(target_url, headers={"Accept": "application/json"})
if api_key_value:
    request.add_header("Authorization", f"Bearer {api_key_value}")
if cf_access_client_id and cf_access_client_secret:
    request.add_header("CF-Access-Client-Id", cf_access_client_id)
    request.add_header("CF-Access-Client-Secret", cf_access_client_secret)

try:
    with urllib.request.urlopen(request, timeout=timeout_seconds, context=ssl.create_default_context()) as response:
        status = int(getattr(response, "status", 0) or response.getcode() or 0)
        body = response.read().decode("utf-8", errors="replace")
except urllib.error.HTTPError as exc:
    detail = exc.read().decode("utf-8", errors="replace")
    summary = detail.strip().replace("\n", " ")[:200] or exc.reason
    raise SystemExit(f"codexliz transport preflight failed for {target_label}: {target_url} returned HTTP {exc.code} ({summary})")
except (urllib.error.URLError, TimeoutError, OSError, ssl.SSLError, ValueError) as exc:
    raise SystemExit(f"codexliz transport preflight failed for {target_label}: {target_url} ({exc})")

if status != 200:
    raise SystemExit(f"codexliz transport preflight failed for {target_label}: {target_url} returned HTTP {status}")

try:
    payload = json.loads(body)
except json.JSONDecodeError as exc:
    raise SystemExit(f"codexliz transport preflight failed for {target_label}: {target_url} returned invalid JSON ({exc})")

models = []
if isinstance(payload, dict):
    if isinstance(payload.get("data"), list):
        models = payload["data"]
    elif isinstance(payload.get("models"), list):
        models = payload["models"]
elif isinstance(payload, list):
    models = payload

if not models:
    raise SystemExit(
        f"codexliz transport preflight failed for {target_label}: {target_url} returned no models payload"
    )

if expected_model:
    discovered = set()
    for item in models:
        if isinstance(item, str):
            discovered.add(item.strip())
            continue
        if not isinstance(item, dict):
            continue
        for key in ("id", "model", "name"):
            value = str(item.get(key) or "").strip()
            if value:
                discovered.add(value)
    if expected_model not in discovered:
        sample = ", ".join(sorted(model for model in discovered if model)[:6]) or "none"
        raise SystemExit(
            "codexliz transport preflight failed for "
            f"{target_label}: expected model {expected_model!r} not present in {target_url} ({sample})"
        )
PY
}

start_proxy_if_needed() {
  local upstream_base_url="${1:-}"
  local requested_port="${2:-}"
  local existing_pid=""
  local attempt=0
  local selected_port="${requested_port}"
  local started_pid=""
  local port_is_explicit=0

  mkdir -p "${CODEXLIZ_STATE_DIR}"
  if [ -n "${CODEXLIZ_PROXY_PORT}" ]; then
    port_is_explicit=1
  fi

  while :; do
    if [ -z "${selected_port}" ]; then
      selected_port="$(resolve_proxy_port)"
    fi
    export CODEXLIZ_PROXY_PORT="${selected_port}"
    write_proxy_port_file "${selected_port}"

    if [ -f "${CODEXLIZ_PROXY_PID_FILE}" ]; then
      existing_pid="$(cat "${CODEXLIZ_PROXY_PID_FILE}" 2>/dev/null || true)"
    else
      existing_pid=""
    fi

    if [ -n "${existing_pid}" ] && process_is_running "${existing_pid}" && proxy_is_ready "${CODEXLIZ_PROXY_HOST}" "${selected_port}" >/dev/null 2>&1; then
      return 0
    fi

    rm -f "${CODEXLIZ_PROXY_PID_FILE}"

    nohup "${PROXY_PYTHON}" "${PROXY_SCRIPT}" \
      --listen-host "${CODEXLIZ_PROXY_HOST}" \
      --listen-port "${selected_port}" \
      --upstream-base-url "${upstream_base_url}" \
      >>"${CODEXLIZ_PROXY_LOG_FILE}" 2>&1 &
    started_pid="$!"
    printf '%s\n' "${started_pid}" > "${CODEXLIZ_PROXY_PID_FILE}"

    attempt=0
    while [ "${attempt}" -lt 15 ]; do
      if proxy_is_ready "${CODEXLIZ_PROXY_HOST}" "${selected_port}" >/dev/null 2>&1; then
        return 0
      fi
      attempt=$((attempt + 1))
      sleep 0.25
    done

    if [ -n "${started_pid}" ] && process_is_running "${started_pid}"; then
      kill "${started_pid}" >/dev/null 2>&1 || true
    fi
    rm -f "${CODEXLIZ_PROXY_PID_FILE}"
    if [ "${port_is_explicit}" -eq 1 ]; then
      break
    fi
    selected_port="$(select_free_proxy_port)"
    write_proxy_port_file "${selected_port}"
  done

  echo "codexliz proxy failed to start on ${CODEXLIZ_PROXY_HOST}:${selected_port}" >&2
  echo "Inspect ${CODEXLIZ_PROXY_LOG_FILE} for details." >&2
  exit 1
}

PRIMARY_COMMAND="$(detect_primary_command "$@")"

export CODEX_PREFER_EA_MCP="${CODEX_PREFER_EA_MCP:-0}"
export CODEX_WRAPPER_DISABLE_BOOTSTRAP="${CODEX_WRAPPER_DISABLE_BOOTSTRAP:-1}"
load_cf_access_env

if { [ "$#" -gt 0 ] && [ -z "${PRIMARY_COMMAND}" ]; } || is_providerless_command "${PRIMARY_COMMAND}" || has_explicit_provider_override "$@"; then
  emit_debug_trace "passthrough primary=${PRIMARY_COMMAND:-none} reason=providerless_or_override log=${CODEXLIZ_DEBUG_LOG_FILE}"
  emit_debug_command "launch" "${BASE_CODEX_SHIM}" "$@"
  exec "${BASE_CODEX_SHIM}" "$@"
fi

declare -a ADJUSTED_ARGS=()
mapfile -d '' ADJUSTED_ARGS < <(wrap_prompt_invocation_with_exec "$@")
PRIMARY_COMMAND="$(detect_primary_command "${ADJUSTED_ARGS[@]}")"

if [ ! -f "${PROXY_SCRIPT}" ]; then
  echo "Missing codexliz proxy script at ${PROXY_SCRIPT}" >&2
  exit 1
fi

REMOTE_UPSTREAM_BASE_URL="$(normalize_remote_upstream_base_url "${CODEXLIZ_BASE_URL}")"
CODEXLIZ_PROXY_PORT="$(resolve_proxy_port)"
LOCAL_PROVIDER_BASE_URL="$(build_local_provider_base_url "${CODEXLIZ_PROXY_PORT}")"
REMOTE_MODELS_URL="$(build_preflight_url "${REMOTE_UPSTREAM_BASE_URL}" "${CODEXLIZ_PREFLIGHT_MODELS_PATH}")"
LOCAL_MODELS_URL="$(build_preflight_url "${LOCAL_PROVIDER_BASE_URL}" "${CODEXLIZ_PREFLIGHT_MODELS_PATH}")"

emit_debug_trace "preflight primary=${PRIMARY_COMMAND:-none} remote=${REMOTE_MODELS_URL} local=${LOCAL_MODELS_URL} proxy_port=${CODEXLIZ_PROXY_PORT} retry=${CODEXLIZ_TRANSPORT_RETRY_ENABLED} log=${CODEXLIZ_DEBUG_LOG_FILE}"

run_models_preflight "${REMOTE_MODELS_URL}" "remote /v1/models" "${CODEXLIZ_MODEL}"

start_proxy_if_needed "${REMOTE_UPSTREAM_BASE_URL}"
run_models_preflight "${LOCAL_MODELS_URL}" "local proxy /v1/models" "${CODEXLIZ_MODEL}"

declare -a provider_args=(
  -c "model_provider=\"${CODEXLIZ_PROVIDER_KEY}\""
  -c "model_providers.${CODEXLIZ_PROVIDER_KEY}.name=\"${CODEXLIZ_PROVIDER_NAME}\""
  -c "model_providers.${CODEXLIZ_PROVIDER_KEY}.base_url=\"${LOCAL_PROVIDER_BASE_URL}\""
  -c "model_providers.${CODEXLIZ_PROVIDER_KEY}.wire_api=\"responses\""
)

if [ -n "${CODEXLIZ_API_KEY_ENV_VAR}" ] && [ -n "${!CODEXLIZ_API_KEY_ENV_VAR:-}" ]; then
  provider_args+=(
    -c "model_providers.${CODEXLIZ_PROVIDER_KEY}.bearer_token_env_var=\"${CODEXLIZ_API_KEY_ENV_VAR}\""
  )
fi

if [ -n "${CODEXLIZ_MODEL}" ] && ! has_explicit_model_override "${ADJUSTED_ARGS[@]}"; then
  provider_args+=(-c "model=\"${CODEXLIZ_MODEL}\"")
fi

OUTPUT_LAST_MESSAGE_PATH="$(detect_output_last_message_path "${ADJUSTED_ARGS[@]}")"
emit_debug_command "launch" "${BASE_CODEX_SHIM}" "${provider_args[@]}" "${ADJUSTED_ARGS[@]}"
if [ "${CODEXLIZ_TRANSPORT_RETRY_ENABLED}" = "0" ]; then
  exec "${BASE_CODEX_SHIM}" "${provider_args[@]}" "${ADJUSTED_ARGS[@]}"
fi
run_codex_with_transport_retry "${OUTPUT_LAST_MESSAGE_PATH}" "${BASE_CODEX_SHIM}" "${provider_args[@]}" "${ADJUSTED_ARGS[@]}"
exit $?
