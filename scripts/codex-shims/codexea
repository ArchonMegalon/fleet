wrap_prompt_invocation_with_exec() {
  local -a args=("$@")
  local -a exec_prefix=()
  local -a exec_only_args=()
  local -a prefix_args=()
  local arg
  local has_skip_git_repo_check=0
  local prompt_exec_workdir=""
  local i=0

  exec_prefix=(exec)
  if env_truthy "${CODEXEA_OPERATOR_GUARD_ACTIVE:-0}" && ! inside_git_repository; then
    prompt_exec_workdir="$(select_default_workdir || true)"
    if [ -n "${prompt_exec_workdir}" ]; then
      prefix_args+=(-C "${prompt_exec_workdir}")
    fi
  fi
  if env_truthy "${CODEXEA_SKIP_GIT_REPO_CHECK:-0}" && real_codex_supports_skip_git_repo_check; then
    for arg in "${args[@]}"; do
      if [ "${arg}" = "--skip-git-repo-check" ]; then
        has_skip_git_repo_check=1
        break
      fi
    done
    if [ "${has_skip_git_repo_check}" -eq 0 ]; then
      exec_prefix+=(--skip-git-repo-check)
    fi
  fi

  if [ "${#args[@]}" -gt 0 ] && [ "${args[0]}" = "exec" ]; then
    if [ "${#prefix_args[@]}" -gt 0 ]; then
      printf '%s\0' "${prefix_args[@]}"
    fi
    printf '%s\0' "${exec_prefix[@]}"
    if [ "${#exec_only_args[@]}" -gt 0 ]; then
      printf '%s\0' "${exec_only_args[@]}"
    fi
    printf '%s\0' "${args[@]:1}"
    return
  fi

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --json|--ephemeral)
        exec_only_args+=("${args[$i]}")
        i=$((i + 1))
        ;;
      -o|--output-last-message|--color|--output-schema)
        exec_only_args+=("${args[$i]}")
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          exec_only_args+=("${args[$i]}")
        fi
        i=$((i + 1))
        ;;
      --)
        if [ "${#prefix_args[@]}" -gt 0 ]; then
          printf '%s\0' "${prefix_args[@]}"
        fi
        printf '%s\0' "${exec_prefix[@]}"
        if [ "${#exec_only_args[@]}" -gt 0 ]; then
          printf '%s\0' "${exec_only_args[@]}"
        fi
        printf '%s\0' "${args[@]:${i}}"
        return
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir)
        prefix_args+=("${args[$i]}")
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          prefix_args+=("${args[$i]}")
        fi
        i=$((i + 1))
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|-h|--help|-V|--version)
        prefix_args+=("${args[$i]}")
        i=$((i + 1))
        ;;
      -*)
        prefix_args+=("${args[$i]}")
        i=$((i + 1))
        ;;
      *)
        if [ "${#prefix_args[@]}" -gt 0 ]; then
          printf '%s\0' "${prefix_args[@]}"
        fi
        printf '%s\0' "${exec_prefix[@]}"
        if [ "${#exec_only_args[@]}" -gt 0 ]; then
          printf '%s\0' "${exec_only_args[@]}"
        fi
        printf '%s\0' "${args[@]:${i}}"
        return
        ;;
    esac
  done

  if [ "${#prefix_args[@]}" -gt 0 ]; then
    printf '%s\0' "${prefix_args[@]}"
  fi
  printf '%s\0' "${exec_prefix[@]}"
  if [ "${#exec_only_args[@]}" -gt 0 ]; then
    printf '%s\0' "${exec_only_args[@]}"
  fi
}

