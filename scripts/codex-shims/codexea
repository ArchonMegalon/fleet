prepend_exec_trace_prompt_to_exec_args() {
  local -a args=("$@")
  local prompt_prefix=""
  local i=0
  local idx=-1

  [ "${#args[@]}" -gt 0 ] || return 1
  [ "${args[0]}" = "exec" ] || {
    printf '%s\0' "${args[@]}"
    return
  }
  prompt_prefix="$(build_exec_trace_prompt)"
  if [ -z "${prompt_prefix}" ]; then
    printf '%s\0' "${args[@]}"
    return
  fi

  i=1
  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --)
        i=$((i + 1))
        if [ "${i}" -lt "${#args[@]}" ]; then
          idx="${i}"
        fi
        break
        ;;
      --json|--ephemeral)
        i=$((i + 1))
        ;;
      -o|--output-last-message|--color|--output-schema|-m|--model|-c|--config|--enable|--disable|-i|--image|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir|--remote|--remote-auth-token-env)
        i=$((i + 2))
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen)
        i=$((i + 1))
        ;;
      -*)
        i=$((i + 1))
        ;;
      *)
        idx="${i}"
        break
        ;;
    esac
  done

  if [ "${idx}" -lt 0 ] || [ "${idx}" -ge "${#args[@]}" ]; then
    printf '%s\0' "${args[@]}"
    return
  fi
  if [ "${args[$idx]}" = "-" ]; then
    printf '%s\0' "${args[@]}"
    return
  fi
  case "${args[$idx]}" in
    "${prompt_prefix}"*)
      printf '%s\0' "${args[@]}"
      return
      ;;
  esac
  if env_truthy "${CODEXEA_OPERATOR_GUARD_ACTIVE:-0}" || [[ "${prompt_prefix}" == *"Operator-prepared "* ]]; then
    args[$idx]="${prompt_prefix}"
    printf '%s\0' "${args[@]}"
    return
  fi
  args[$idx]="${prompt_prefix}"$'\n\n'"${args[$idx]}"
  printf '%s\0' "${args[@]}"
}

operator_guard_candidate_text() {
  local primary_command=""
  local -a args=("$@")

  [ "$#" -gt 0 ] || return 1
  primary_command="$(detect_primary_command "$@")"
  if [ "${primary_command}" = "exec" ] || [ "${1:-}" = "exec" ]; then
    if [ "${#args[@]}" -gt 0 ] && is_codexea_lane "${args[0]}"; then
      args=("${args[@]:1}")
    fi
    extract_exec_prompt_text "${args[@]}"
    return $?
  fi
  if [ -n "${primary_command}" ] && { is_codex_subcommand "${primary_command}" || is_codexea_lane "${primary_command}"; }; then
    return 1
  fi
  printf '%s' "$*"
}

