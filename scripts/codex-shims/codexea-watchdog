#!/usr/bin/env python3
from __future__ import annotations

import errno
import fcntl
import json
import os
import pty
import re
import select
import signal
import socket
import sys
import termios
import time
import tty
from typing import Callable


DEFAULT_INTERVAL = int(os.environ.get("CODEXEA_WATCHDOG_INTERVAL", "15"))
DEFAULT_PROMPT = os.environ.get(
    "CODEXEA_WATCHDOG_PROMPT",
    "",
)
DEFAULT_INTERRUPT_INTERVALS = int(os.environ.get("CODEXEA_WATCHDOG_INTERRUPT_INTERVALS", "1"))
DEFAULT_RESTART_GRACE_SECONDS = float(os.environ.get("CODEXEA_WATCHDOG_RESTART_GRACE_SECONDS", "0.5"))
DEFAULT_WAIT_GRACE_SECONDS = float(
    os.environ.get(
        "CODEXEA_WATCHDOG_WAIT_GRACE_SECONDS",
        os.environ.get("CODEXEA_EXEC_HARD_TIMEOUT_SECONDS", "3600"),
    )
)
STATE_DIR = os.path.expanduser(os.environ.get("CODEXEA_STATE_DIR", "~/.cache/codexea"))
STOP_FILE = os.path.expanduser(os.environ.get("CODEXEA_STOP_FILE", os.path.join(STATE_DIR, "stop")))
SESSIONS_DIR = os.path.expanduser("~/.codex/sessions")
HISTORY_FILE = os.path.expanduser("~/.codex/history.jsonl")
SESSION_ID_RE = re.compile(r"([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})", re.IGNORECASE)
ACTIVE_SESSION_RE = re.compile(
    r"Session:\s*([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})",
    re.IGNORECASE,
)
ANSI_RE = re.compile(r"\x1b(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~]|\].*?(?:\x07|\x1b\\))")
SYNTHETIC_WAIT_RE = re.compile(
    r"^(Trace:\s*)?(lane=[^\s]+\s+)?waiting for (upstream response|model output)\b",
    re.IGNORECASE,
)
SYNTHETIC_TRANSPORT_RE = re.compile(
    r"^Trace:\s*provider=[^\s]+\s+transport=(outage|reconnecting|waiting|retrying)\b",
    re.IGNORECASE,
)
RECONNECTING_RE = re.compile(r"^Reconnecting\.\.\.\s+\d+/\d+\b", re.IGNORECASE)
TRANSPORT_DETAIL_RE = re.compile(
    r"(stream disconnected before completion|error sending request for url|proxy_upstream_failure|read operation timed out)",
    re.IGNORECASE,
)

MEANINGFUL_MARKERS = (
    "Trace:",
    "Explored",
    "Read ",
    "Ran ",
    "Updated ",
    "Edited ",
    "Applied ",
    "Created ",
    "Deleted ",
    "Thinking",
    "Plan:",
    "Error",
    "Failed",
    "Conversation interrupted",
    "Completed",
)


def _set_nonblocking(fd: int) -> None:
    flags = fcntl.fcntl(fd, fcntl.F_GETFL)
    fcntl.fcntl(fd, fcntl.F_SETFL, flags | os.O_NONBLOCK)


def _sync_winsize(from_fd: int, to_fd: int) -> None:
    try:
        winsize = fcntl.ioctl(from_fd, termios.TIOCGWINSZ, b"\0" * 8)
        fcntl.ioctl(to_fd, termios.TIOCSWINSZ, winsize)
    except OSError:
        pass


def _write_all(fd: int, data: bytes) -> None:
    view = memoryview(data)
    while view:
        try:
            written = os.write(fd, view)
            view = view[written:]
        except (BlockingIOError, InterruptedError):
            select.select([], [fd], [], 0.25)
        except OSError as exc:
            if exc.errno in (socket.EAGAIN, socket.EWOULDBLOCK):
                select.select([], [fd], [], 0.25)
                continue
            raise


def _activity_state(data: bytes) -> str:
    text = data.decode("utf-8", "ignore")
    text = ANSI_RE.sub("", text)
    lines = [" ".join(line.split()) for line in text.splitlines()]
    visible = [line for line in lines if line]
    if not visible:
        return "none"
    saw_wait = False
    for line in visible:
        if line.startswith(("• Working", "◦ Working", "Working (")):
            saw_wait = True
            continue
        if "esc to interrupt" in line and "Working" in line:
            saw_wait = True
            continue
        if SYNTHETIC_WAIT_RE.search(line):
            saw_wait = True
            continue
        if SYNTHETIC_TRANSPORT_RE.search(line):
            saw_wait = True
            continue
        if RECONNECTING_RE.search(line):
            saw_wait = True
            continue
        if TRANSPORT_DETAIL_RE.search(line):
            saw_wait = True
            continue
        if any(marker in line for marker in MEANINGFUL_MARKERS):
            return "meaningful"
    if saw_wait:
        return "waiting"
    return "none"


def _has_meaningful_progress(data: bytes) -> bool:
    return _activity_state(data) == "meaningful"


def _wait_signal_freshness_seconds(interval: int | float) -> float:
    return max(5.0, float(interval) * 2.0)


def _should_hold_wait_session(
    *,
    now: float,
    wait_started_at: float,
    last_wait_signal: float,
    interval: int | float,
    wait_grace_seconds: float,
) -> bool:
    if wait_grace_seconds <= 0 or wait_started_at <= 0 or last_wait_signal <= 0:
        return False
    if (now - wait_started_at) > wait_grace_seconds:
        return False
    return (now - last_wait_signal) <= _wait_signal_freshness_seconds(interval)


def _launch_child(argv: list[str], resume_prompt: str | None = None, resume_session_id: str | None = None) -> tuple[int, int]:
    master_fd, slave_fd = pty.openpty()
    child_pid = os.fork()
    if child_pid == 0:
        try:
            os.setsid()
            os.close(master_fd)
            os.dup2(slave_fd, 0)
            os.dup2(slave_fd, 1)
            os.dup2(slave_fd, 2)
            if slave_fd > 2:
                os.close(slave_fd)
            os.environ["CODEXEA_WATCHDOG_ACTIVE"] = "1"
            if resume_prompt is not None or resume_session_id is not None:
                os.environ["CODEXEA_WATCHDOG_RESUME_PROMPT"] = resume_prompt or ""
                session_id = resume_session_id or _latest_session_id()
                if session_id:
                    os.environ["CODEXEA_WATCHDOG_RESUME_SESSION_ID"] = session_id
                else:
                    os.environ.pop("CODEXEA_WATCHDOG_RESUME_SESSION_ID", None)
            else:
                os.environ.pop("CODEXEA_WATCHDOG_RESUME_PROMPT", None)
                os.environ.pop("CODEXEA_WATCHDOG_RESUME_SESSION_ID", None)
            os.environ["CODEXEA_BOOTSTRAP"] = "0"
            os.execv(argv[0], argv)
        finally:
            os._exit(127)
    os.close(slave_fd)
    return master_fd, child_pid


def _terminate_child(child_pid: int, master_fd: int) -> int:
    try:
        os.kill(child_pid, signal.SIGINT)
    except ProcessLookupError:
        pass
    deadline = time.monotonic() + DEFAULT_RESTART_GRACE_SECONDS
    while time.monotonic() < deadline:
        pid, status = os.waitpid(child_pid, os.WNOHANG)
        if pid == child_pid:
            os.close(master_fd)
            return status
        time.sleep(0.1)
    try:
        os.kill(child_pid, signal.SIGTERM)
    except ProcessLookupError:
        pass
    deadline = time.monotonic() + 1.0
    while time.monotonic() < deadline:
        pid, status = os.waitpid(child_pid, os.WNOHANG)
        if pid == child_pid:
            os.close(master_fd)
            return status
        time.sleep(0.1)
    try:
        os.kill(child_pid, signal.SIGKILL)
    except ProcessLookupError:
        pass
    _, status = os.waitpid(child_pid, 0)
    os.close(master_fd)
    return status


def _latest_session_id() -> str:
    try:
        with open(HISTORY_FILE, "r", encoding="utf-8", errors="ignore") as handle:
            for line in reversed(handle.readlines()):
                try:
                    payload = json.loads(line)
                except json.JSONDecodeError:
                    continue
                session_id = payload.get("session_id")
                if isinstance(session_id, str) and SESSION_ID_RE.fullmatch(session_id):
                    return session_id
    except OSError:
        pass

    newest_mtime = -1.0
    newest_session_id = ""
    for root, _, files in os.walk(SESSIONS_DIR):
        for name in files:
            match = SESSION_ID_RE.search(name)
            if not match:
                continue
            path = os.path.join(root, name)
            try:
                mtime = os.path.getmtime(path)
            except OSError:
                continue
            if mtime > newest_mtime:
                newest_mtime = mtime
                newest_session_id = match.group(1)
    return newest_session_id


def _extract_active_session_id(data: bytes) -> str:
    text = ANSI_RE.sub("", data.decode("utf-8", "ignore"))
    match = ACTIVE_SESSION_RE.search(text)
    return match.group(1) if match else ""


def _stop_requested() -> bool:
    return os.path.exists(STOP_FILE)


def main(argv: list[str]) -> int:
    codexea = os.environ.get("CODEXEA_WATCHDOG_TARGET", os.path.expanduser("~/.local/bin/codexea"))
    interval = DEFAULT_INTERVAL
    child_argv = [codexea, *argv]

    if not os.path.exists(codexea):
        print(f"Missing codexea launcher: {codexea}", file=sys.stderr)
        return 1
    os.makedirs(STATE_DIR, exist_ok=True)
    if _stop_requested():
        print("[watchdog] stop latch set; not starting", file=sys.stderr)
        return 0

    stdin_fd = sys.stdin.fileno()
    stdin_is_tty = os.isatty(stdin_fd)
    old_tty = termios.tcgetattr(stdin_fd) if stdin_is_tty else None
    previous_winch_handler: int | Callable[[int, object], None] | None = None
    master_fd, child_pid = _launch_child(child_argv)
    active_session_id = ""
    if stdin_is_tty:
        tty.setraw(stdin_fd)
    if stdin_is_tty:
        _sync_winsize(stdin_fd, master_fd)
        _set_nonblocking(stdin_fd)

    def _prepare_master_fd() -> None:
        _set_nonblocking(master_fd)
        if stdin_is_tty:
            _sync_winsize(stdin_fd, master_fd)

    def _handle_winch(signum: int, frame: object) -> None:
        _sync_winsize(stdin_fd, master_fd)
        try:
            os.kill(child_pid, signal.SIGWINCH)
        except ProcessLookupError:
            pass

    _prepare_master_fd()
    if stdin_is_tty:
        previous_winch_handler = signal.signal(signal.SIGWINCH, _handle_winch)

    last_activity = time.monotonic()
    last_wait_signal = 0.0
    wait_started_at = 0.0
    idle_nudges = 0

    try:
        while True:
            if _stop_requested():
                _write_all(sys.stdout.fileno(), b"\n[watchdog] stop latch set; stopping\n")
                _terminate_child(child_pid, master_fd)
                return 0
            now = time.monotonic()
            timeout = max(0.25, interval - (now - last_activity))
            watched_fds = [master_fd]
            if stdin_is_tty:
                watched_fds.append(stdin_fd)
            rlist, _, _ = select.select(watched_fds, [], [], timeout)

            if master_fd in rlist:
                try:
                    data = os.read(master_fd, 65536)
                except BlockingIOError:
                    data = b""
                except OSError as exc:
                    if exc.errno == errno.EIO:
                        data = b""
                    else:
                        raise
                if not data:
                    break
                _write_all(sys.stdout.fileno(), data)
                observed_session_id = _extract_active_session_id(data)
                if observed_session_id:
                    active_session_id = observed_session_id
                activity_state = _activity_state(data)
                if activity_state == "meaningful":
                    now = time.monotonic()
                    last_activity = now
                    last_wait_signal = 0.0
                    wait_started_at = 0.0
                    idle_nudges = 0
                elif activity_state == "waiting":
                    now = time.monotonic()
                    last_wait_signal = now
                    if wait_started_at <= 0:
                        wait_started_at = now

            if stdin_is_tty and stdin_fd in rlist:
                try:
                    user_data = os.read(stdin_fd, 65536)
                except BlockingIOError:
                    user_data = b""
                if user_data:
                    os.write(master_fd, user_data)
                    last_activity = time.monotonic()
                    last_wait_signal = 0.0
                    wait_started_at = 0.0
                    idle_nudges = 0

            now = time.monotonic()
            if _should_hold_wait_session(
                now=now,
                wait_started_at=wait_started_at,
                last_wait_signal=last_wait_signal,
                interval=interval,
                wait_grace_seconds=DEFAULT_WAIT_GRACE_SECONDS,
            ):
                last_activity = now
                continue
            if now - last_activity >= interval:
                idle_nudges += 1
                if idle_nudges >= DEFAULT_INTERRUPT_INTERVALS:
                    _write_all(
                        sys.stdout.fileno(),
                        b"\n[watchdog] resuming stalled session\n",
                    )
                    _terminate_child(child_pid, master_fd)
                    master_fd, child_pid = _launch_child(child_argv, DEFAULT_PROMPT, active_session_id or None)
                    active_session_id = ""
                    last_wait_signal = 0.0
                    wait_started_at = 0.0
                    _prepare_master_fd()
                    _write_all(
                        sys.stdout.fileno(),
                        b"[watchdog] resumed session\n",
                    )
                    idle_nudges = 0
                else:
                    _write_all(
                        sys.stdout.fileno(),
                        b"\n[watchdog] still waiting on the current slice\n",
                    )
                    _write_all(
                        sys.stdout.fileno(),
                        b"[watchdog] waiting before resume\n",
                    )
                last_activity = time.monotonic()

            pid, status = os.waitpid(child_pid, os.WNOHANG)
            if pid == child_pid:
                if os.WIFEXITED(status):
                    return os.WEXITSTATUS(status)
                if os.WIFSIGNALED(status):
                    return 128 + os.WTERMSIG(status)
                return 1
    except KeyboardInterrupt:
        try:
            os.kill(child_pid, signal.SIGINT)
        except ProcessLookupError:
            pass
        return 130
    finally:
        if stdin_is_tty and old_tty is not None:
            termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_tty)
        if previous_winch_handler is not None:
            signal.signal(signal.SIGWINCH, previous_winch_handler)
        os.close(master_fd)

    pid, status = os.waitpid(child_pid, 0)
    if os.WIFEXITED(status):
        return os.WEXITSTATUS(status)
    if os.WIFSIGNALED(status):
        return 128 + os.WTERMSIG(status)
    return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
