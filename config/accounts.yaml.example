# Fleet routes by EA lane alias first.
# Keep one EA alias per lane, then let task policy decide whether paid lanes are allowed.
# Raw model allowlists remain a legacy compatibility fallback; `lane` + `codex_model_aliases`
# are the routing truth for Fleet itself.
account_policy:
  protected_owner_ids:
    - archon.megalon
    - the.girscheles
    - tibor.girschele
  classes:
    protected_operator:
      drain_policy: never
      allowed_roles:
        - studio
        - core_authority
        - jury
        - core_rescue
        - emergency_fallback
    participant_funded:
      drain_policy: first
      eligible_pools:
        - participant_burst
      requires:
        - explicit_consent
        - valid_token_pool
        - work_lease
        - scope_lease

accounts:
  acct-ea-fleet:
    auth_kind: ea
    allowed_models: [ea-gemini-flash]
    health_state: ready
    daily_budget_usd: 20
    monthly_budget_usd: 200
    max_parallel_runs: 2
    bridge_name: EA Fleet Worker
    bridge_fallback_accounts: [acct-ea-groundwork, acct-ea-review-light, acct-ea-jury, acct-ea-core]
    lane: easy
    codex_model_aliases: [ea-gemini-flash]

  acct-ea-groundwork:
    auth_kind: ea
    allowed_models: [ea-groundwork-gemini]
    health_state: ready
    daily_budget_usd: 10
    monthly_budget_usd: 100
    max_parallel_runs: 2
    lane: groundwork
    codex_model_aliases: [ea-groundwork-gemini]

  acct-ea-groundwork-2:
    auth_kind: ea
    allowed_models: [ea-groundwork-gemini]
    health_state: ready
    daily_budget_usd: 10
    monthly_budget_usd: 100
    max_parallel_runs: 2
    bridge_name: EA Groundwork Shadow
    lane: groundwork
    codex_model_aliases: [ea-groundwork-gemini]

  acct-ea-review-light:
    auth_kind: ea
    allowed_models: [ea-review-light, ea-coder-hard-batch]
    health_state: ready
    daily_budget_usd: 10
    monthly_budget_usd: 100
    max_parallel_runs: 3
    lane: review_light
    codex_model_aliases: [ea-review-light, ea-coder-hard-batch]

  acct-ea-jury:
    auth_kind: ea
    allowed_models: [ea-audit-jury, ea-coder-hard-batch]
    health_state: ready
    daily_budget_usd: 10
    monthly_budget_usd: 100
    max_parallel_runs: 3
    lane: jury
    codex_model_aliases: [ea-audit-jury, ea-coder-hard-batch]

  acct-ea-repair:
    auth_kind: ea
    allowed_models: [ea-coder-fast]
    health_state: ready
    daily_budget_usd: 15
    monthly_budget_usd: 150
    max_parallel_runs: 1
    lane: repair
    codex_model_aliases: [ea-coder-fast]

  acct-ea-core:
    auth_kind: ea
    allowed_models: [ea-coder-hard]
    health_state: ready
    # Leave account budgets unset for 1min core so quartermaster/onemin credits stay authoritative.
    max_parallel_runs: 1
    lane: core
    funding_class: operator_funded
    drain_policy: remainder
    codex_model_aliases: [ea-coder-hard]

  acct-ea-survival:
    auth_kind: ea
    allowed_models: [ea-coder-survival]
    health_state: ready
    daily_budget_usd: 5
    monthly_budget_usd: 50
    max_parallel_runs: 1
    lane: survival
    codex_model_aliases: [ea-coder-survival]

  # Optional project-local API key accounts live below the lane aliases. They can still back
  # Studio, one-off projects, or bridge fallbacks, but they are not Fleet's routing truth.
  acct-core-a:
    auth_kind: api_key
    api_key_env: OPENAI_API_KEY
    allowed_models: [gpt-5-mini, gpt-5.4, gpt-5.3-codex]
    health_state: ready
    daily_budget_usd: 30
    monthly_budget_usd: 300
    max_parallel_runs: 1
    owner_id: tibor.girschele
    account_class: protected_operator
    drain_policy: never
    allowed_roles: [studio, core_authority, jury, core_rescue, emergency_fallback]

  acct-ui-a:
    auth_kind: api_key
    api_key_env: OPENAI_API_KEY
    allowed_models: [gpt-5-mini, gpt-5.4]
    health_state: ready
    daily_budget_usd: 20
    monthly_budget_usd: 200
    max_parallel_runs: 1
    owner_id: the.girscheles
    account_class: protected_operator
    drain_policy: never
    allowed_roles: [studio, core_authority, jury, core_rescue, emergency_fallback]

  acct-hub-a:
    auth_kind: api_key
    api_key_env: OPENAI_API_KEY
    allowed_models: [gpt-5-mini, gpt-5.4]
    health_state: ready
    daily_budget_usd: 20
    monthly_budget_usd: 200
    max_parallel_runs: 1
    owner_id: the.girscheles
    account_class: protected_operator
    drain_policy: never
    allowed_roles: [studio, core_authority, jury, core_rescue, emergency_fallback]

  acct-ea-a:
    auth_kind: api_key
    api_key_env: OPENAI_API_KEY
    allowed_models: [gpt-5-nano, gpt-5-mini, gpt-5.4]
    health_state: ready
    daily_budget_usd: 10
    monthly_budget_usd: 100
    max_parallel_runs: 1
    owner_id: the.girscheles
    account_class: protected_operator
    drain_policy: never
    allowed_roles: [studio, core_authority, jury, core_rescue, emergency_fallback]

  acct-studio-a:
    auth_kind: api_key
    api_key_env: OPENAI_API_KEY
    allowed_models: [gpt-5-mini, gpt-5.4]
    health_state: ready
    daily_budget_usd: 25
    monthly_budget_usd: 250
    max_parallel_runs: 1
    owner_id: tibor.girschele
    account_class: protected_operator
    drain_policy: never
    allowed_roles: [studio, core_authority, jury, core_rescue, emergency_fallback]

  acct-shared-b:
    auth_kind: api_key
    api_key_env: OPENAI_API_KEY
    allowed_models: [gpt-5-nano, gpt-5-mini, gpt-5.4, gpt-5.3-codex]
    health_state: ready
    daily_budget_usd: 50
    monthly_budget_usd: 500
    max_parallel_runs: 1
    owner_id: the.girscheles
    account_class: protected_operator
    drain_policy: never
    allowed_roles: [studio, core_authority, jury, core_rescue, emergency_fallback]

  acct-chatgpt-core:
    auth_kind: chatgpt_auth_json
    auth_json_file: /run/secrets/acct-chatgpt-core.auth.json
    allowed_models: [gpt-5.3-codex-spark, gpt-5.4, gpt-5.3-codex]
    spark_enabled: true
    health_state: ready
    max_parallel_runs: 1
    owner_id: tibor.girschele
    account_class: protected_operator
    drain_policy: never
    allowed_roles: [studio, core_authority, jury, core_rescue, emergency_fallback]
    # optional hard guardrails for managed environments:
    # forced_login_method: chatgpt
    # forced_chatgpt_workspace_id: 00000000-0000-0000-0000-000000000000

  acct-chatgpt-b:
    auth_kind: chatgpt_auth_json
    auth_json_file: /run/secrets/acct-chatgpt-b.auth.json
    allowed_models: [gpt-5-mini, gpt-5.4]
    spark_enabled: false
    health_state: ready
    max_parallel_runs: 1
    owner_id: the.girscheles
    account_class: protected_operator
    drain_policy: never
    allowed_roles: [studio, core_authority, jury, core_rescue, emergency_fallback]

  acct-chatgpt-archon:
    auth_kind: chatgpt_auth_json
    auth_json_file: /run/secrets/acct-chatgpt-archon.auth.json
    allowed_models: [gpt-5.3-codex-spark, gpt-5.4, gpt-5.3-codex]
    spark_enabled: true
    health_state: ready
    max_parallel_runs: 1
    owner_id: archon.megalon
    account_class: protected_operator
    drain_policy: never
    allowed_roles: [studio, core_authority, jury, core_rescue, emergency_fallback]

  # Participant-sponsored premium burst lanes are registered dynamically at runtime.
  # They behave like lane-scoped ChatGPT auth accounts after explicit Hub consent.

# For api_key accounts, set either api_key_env or api_key_file.
# If both are set, api_key_env takes precedence.
# Spark-capable aliases must use ChatGPT auth; API-key aliases should not advertise gpt-5.3-codex-spark.
# If multiple aliases share the same ChatGPT auth.json, treat them as one effective human account lane.
# Fleet-wide safe parallelism should track the number of distinct real auth caches, not alias count.
# Participant-sponsored premium burst lanes do not replace the cheap baseline; they are additive core-capacity lanes.
# If a project keeps allow_chatgpt_accounts=true and allow_api_accounts=true in fleet.yaml,
# the broker will use either auth class and still keep Spark on ChatGPT-authenticated aliases only.
