def _repo_root_for_path(path: Path) -> Path | None:
    current = path.parent if path.is_file() else path
    for candidate in (current, *current.parents):
        git_marker = candidate / ".git"
        if git_marker.exists():
            return candidate
    return None


def _build_repo_diff_commands(commands: list[str]) -> list[str]:
    path_groups: dict[str, list[str]] = {}
    seen_paths: set[str] = set()
    for command in commands:
        for match in __import__("re").findall(r"(/[A-Za-z0-9._/\-]+)", str(command or "")):
            raw_path = str(match or "").strip()
            if not raw_path or raw_path in seen_paths:
                continue
            path = Path(raw_path)
            if not path.exists() or not path.is_file():
                continue
            repo_root_path = _repo_root_for_path(path)
            if repo_root_path is None:
                continue
            try:
                rel_path = str(path.relative_to(repo_root_path))
            except Exception:
                continue
            repo_root = str(repo_root_path)
            if not repo_root:
                continue
            path_groups.setdefault(repo_root, []).append(rel_path)
            seen_paths.add(raw_path)
    result: list[str] = []
    for repo_root, rel_paths in path_groups.items():
        unique_rel_paths = _dedupe(rel_paths)
        if not unique_rel_paths:
            continue
        quoted_root = subprocess.list2cmdline([repo_root])
        quoted_paths = " ".join(subprocess.list2cmdline([item]) for item in unique_rel_paths)
        result.append(f"git -C {quoted_root} status --short -- {quoted_paths}")
        result.append(f"git -C {quoted_root} diff --stat -- {quoted_paths}")
    return result


def _staged_prompt_commands(text: str) -> list[str]:
    prompt = str(text or "")
    if not prompt:
        return []
    stage_markers = (
        "Run these exact commands first:",
        "Safe first commands if you need orientation",
        "Read these files directly first:",
    )
    commands: list[str] = []
    collecting = False
    for raw_line in prompt.splitlines():
        line = str(raw_line or "").rstrip()
        stripped = line.strip()
        if not collecting:
            if any(marker in stripped for marker in stage_markers):
                collecting = True
            continue
        if not stripped:
            if commands:
                break
            continue
        if stripped.startswith("$ "):
            commands.append(stripped[2:].strip())
            continue
        if commands:
            break
    return _dedupe([command for command in commands if command])[:8]


def _compact_prepared_section(text: str, *, max_lines: int = 8, max_chars: int = 900) -> str:
    value = str(text or "").strip()
    if not value:
        return ""
    lines = value.splitlines()
    if len(lines) > max_lines:
        value = "\n".join(lines[:max_lines] + ["... output truncated"])
    if len(value) > max_chars:
        value = value[: max_chars - 3].rstrip() + "..."
    return value


