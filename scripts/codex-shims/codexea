    printf '%s\n' '  "${CHUMMER_DESIGN_SUPERVISOR_REAL_PYTHON3:-/usr/bin/python3}" "${CHUMMER_DESIGN_SUPERVISOR_REDIRECT_HELPER}" --summary-json "${CHUMMER_DESIGN_SUPERVISOR_TASK_LOCAL_TELEMETRY_PATH}" "${CHUMMER_DESIGN_SUPERVISOR_EXEC_STRING_HIT_COUNTER}";'
