#!/usr/bin/env python3
from __future__ import annotations

import argparse
import http.client
import http.server
import json
import os
import socketserver
import ssl
import sys
import urllib.parse


HOP_BY_HOP_HEADERS = {
    "connection",
    "keep-alive",
    "proxy-authenticate",
    "proxy-authorization",
    "te",
    "trailer",
    "transfer-encoding",
    "upgrade",
    "proxy-connection",
}


def _clean_access_value(value: str) -> str:
    token = str(value or "").strip()
    if token.startswith("REPLACE_WITH_"):
        return ""
    return token


def _load_access_headers() -> dict[str, str]:
    client_id = _clean_access_value(
        os.environ.get("CODEXLIZ_CF_ACCESS_CLIENT_ID") or os.environ.get("CF_ACCESS_CLIENT_ID") or ""
    )
    client_secret = _clean_access_value(
        os.environ.get("CODEXLIZ_CF_ACCESS_CLIENT_SECRET") or os.environ.get("CF_ACCESS_CLIENT_SECRET") or ""
    )
    if bool(client_id) != bool(client_secret):
        raise SystemExit("codexliz proxy requires both Cloudflare Access client id and client secret")
    if not client_id:
        return {}
    return {
        "CF-Access-Client-Id": client_id,
        "CF-Access-Client-Secret": client_secret,
    }


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Local HTTP proxy for Codex -> remote HTTPS Ollama bridge.")
    parser.add_argument("--listen-host", default="127.0.0.1")
    parser.add_argument("--listen-port", type=int, default=4141)
    parser.add_argument("--upstream-base-url", required=True)
    parser.add_argument("--connect-timeout-seconds", type=float, default=30.0)
    parser.add_argument("--read-chunk-bytes", type=int, default=65536)
    return parser.parse_args()


class ThreadingHTTPServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    daemon_threads = True
    allow_reuse_address = True


class ProxyHandler(http.server.BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"
    server_version = "codexliz-http-proxy/1.0"

    def do_GET(self) -> None:
        self._handle_proxy()

    def do_POST(self) -> None:
        self._handle_proxy()

    def do_PUT(self) -> None:
        self._handle_proxy()

    def do_PATCH(self) -> None:
        self._handle_proxy()

    def do_DELETE(self) -> None:
        self._handle_proxy()

    def do_OPTIONS(self) -> None:
        self._handle_proxy()

    def do_HEAD(self) -> None:
        self._handle_proxy()

    def log_message(self, fmt: str, *args: object) -> None:
        sys.stderr.write(
            "%s - - [%s] %s\n"
            % (self.address_string(), self.log_date_time_string(), fmt % args)
        )

    def _handle_proxy(self) -> None:
        if self.path == "/healthz":
            payload = json.dumps(
                {
                    "ok": True,
                    "upstream_base_url": self.server.upstream_base_url,
                }
            ).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(payload)))
            self.send_header("Connection", "close")
            self.end_headers()
            if self.command != "HEAD":
                self.wfile.write(payload)
            self.close_connection = True
            return

        try:
            self._forward_request()
        except Exception as exc:
            body = json.dumps(
                {
                    "error": "proxy_upstream_failure",
                    "detail": str(exc),
                }
            ).encode("utf-8")
            self.send_response(502, "Bad Gateway")
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.send_header("Connection", "close")
            self.end_headers()
            if self.command != "HEAD":
                self.wfile.write(body)
            self.close_connection = True

    def _forward_request(self) -> None:
        upstream = urllib.parse.urlsplit(self.server.upstream_base_url)
        target_path = urllib.parse.urlunsplit(("", "", self.path.partition("?")[0], self.path.partition("?")[2], ""))
        if not target_path.startswith("/"):
            target_path = "/" + target_path
        if upstream.path and upstream.path != "/":
            target_path = upstream.path.rstrip("/") + target_path

        body = self._read_request_body()
        headers = self._build_upstream_headers(upstream)
        connection = self._open_upstream_connection(upstream)
        try:
            connection.request(self.command, target_path, body=body, headers=headers)
            response = connection.getresponse()
            self.send_response(response.status, response.reason)
            for name, value in response.getheaders():
                lowered = name.lower()
                if lowered in HOP_BY_HOP_HEADERS:
                    continue
                if lowered == "content-length":
                    self.send_header(name, value)
                    continue
                self.send_header(name, value)
            if response.getheader("Content-Length") is None:
                self.send_header("Connection", "close")
            self.end_headers()
            if self.command != "HEAD":
                while True:
                    chunk = response.read(self.server.read_chunk_bytes)
                    if not chunk:
                        break
                    self.wfile.write(chunk)
                    self.wfile.flush()
        finally:
            connection.close()
            self.close_connection = True

    def _read_request_body(self) -> bytes | None:
        transfer_encoding = self.headers.get("Transfer-Encoding", "")
        if "chunked" in transfer_encoding.lower():
            raise ValueError("chunked request bodies are not supported by codexliz-http-proxy")

        content_length = self.headers.get("Content-Length", "").strip()
        if not content_length:
            return None

        length = int(content_length)
        if length <= 0:
            return None
        return self.rfile.read(length)

    def _build_upstream_headers(self, upstream: urllib.parse.SplitResult) -> dict[str, str]:
        headers: dict[str, str] = {}
        host_header = upstream.netloc
        if host_header:
            headers["Host"] = host_header
        headers["Connection"] = "close"

        for name, value in self.headers.items():
            lowered = name.lower()
            if lowered in HOP_BY_HOP_HEADERS or lowered in {"host", "content-length"}:
                continue
            headers[name] = value
        headers.update(self.server.access_headers)

        return headers

    def _open_upstream_connection(
        self, upstream: urllib.parse.SplitResult
    ) -> http.client.HTTPConnection | http.client.HTTPSConnection:
        host = upstream.hostname or ""
        port = upstream.port
        timeout = self.server.connect_timeout_seconds

        if upstream.scheme == "https":
            context = ssl.create_default_context()
            return http.client.HTTPSConnection(host, port=port, timeout=timeout, context=context)
        if upstream.scheme == "http":
            return http.client.HTTPConnection(host, port=port, timeout=timeout)
        raise ValueError(f"unsupported upstream scheme: {upstream.scheme}")


def main() -> int:
    args = parse_args()
    upstream_base_url = args.upstream_base_url.rstrip("/")
    parsed = urllib.parse.urlsplit(upstream_base_url)
    if parsed.scheme not in {"http", "https"} or not parsed.netloc:
        raise SystemExit(f"invalid upstream base URL: {args.upstream_base_url}")

    server = ThreadingHTTPServer((args.listen_host, args.listen_port), ProxyHandler)
    server.upstream_base_url = upstream_base_url
    server.connect_timeout_seconds = float(args.connect_timeout_seconds)
    server.read_chunk_bytes = max(1024, int(args.read_chunk_bytes))
    server.access_headers = _load_access_headers()

    sys.stderr.write(
        f"[codexliz-http-proxy] listening on http://{args.listen_host}:{args.listen_port} -> {upstream_base_url}\n"
    )
    server.serve_forever()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
