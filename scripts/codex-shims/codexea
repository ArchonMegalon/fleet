args_request_interactive_session() {
  local -a args=("$@")
  local i=0
  local saw_interactive=0
  local primary_command=""

  [ "${#args[@]}" -gt 0 ] || return 1

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --interactive)
        saw_interactive=1
        i=$((i + 1))
        ;;
      --)
        break
        ;;
    esac
    i=$((i + 1))
  done

  [ "${saw_interactive}" -eq 1 ] || return 1
  primary_command="$(detect_primary_command "$@")"
  if [ -n "${primary_command}" ] && is_codex_subcommand "${primary_command}"; then
    return 1
  fi
  return 0
}

strip_interactive_request_flags() {
  local -a args=("$@")
  local i=0

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      --interactive)
        i=$((i + 1))
        ;;
      *)
        printf '%s\0' "${args[$i]}"
        i=$((i + 1))
        ;;
    esac
  done
}

has_explicit_runtime_override() {
  local -a args=("$@")
  local i=0
  local value=""
  local normalized=""

  while [ "${i}" -lt "${#args[@]}" ]; do
    case "${args[$i]}" in
      -m|--model|--oss|--local-provider|-p|--profile)
        return 0
        ;;
      -c|--config)
        i=$((i + 1))
        if [ "${i}" -ge "${#args[@]}" ]; then
          break
        fi
        value="${args[$i]}"
        normalized="${value//[[:space:]]/}"
        case "${normalized}" in
          model=*|model_provider=*|model_providers.*|chatgpt_base_url=*|openai_base_url=*)
            return 0
            ;;
        esac
        ;;
      --)
        return 1
        ;;
    esac
    i=$((i + 1))
  done
  return 1
}

