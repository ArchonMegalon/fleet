script_supports_tty_wrapper() {
  case "${SCRIPT_SUPPORTS_TTY_WRAPPER:-}" in
    1)
      return 0
      ;;
    0)
      return 1
      ;;
  esac

  if ! command -v script >/dev/null 2>&1; then
    SCRIPT_SUPPORTS_TTY_WRAPPER=0
    return 1
  fi

  local help_text=""
  local has_command_long=0
  local has_return_long=0
  local has_command_short=0
  local has_quiet_short=0

  help_text="$(script --help 2>&1 || true)"
  if printf '%s\n' "${help_text}" | grep -q -- "--command"; then
    has_command_long=1
  fi
  if printf '%s\n' "${help_text}" | grep -q -- "--return"; then
    has_return_long=1
  fi
  if printf '%s\n' "${help_text}" | grep -qE '(^|[[:space:]])-c([[:space:]]|$)'; then
    has_command_short=1
  fi
  if printf '%s\n' "${help_text}" | grep -qE '(^|[[:space:]])(-q|--quiet)([[:space:]]|$)'; then
    has_quiet_short=1
  fi

  if [ "${has_command_long}" -eq 1 ] && [ "${has_return_long}" -eq 1 ]; then
    SCRIPT_SUPPORTS_TTY_WRAPPER=1
    SCRIPT_TTY_WRAPPER_STYLE=long
    return 0
  fi

  if [ "${has_command_short}" -eq 1 ] && [ "${has_quiet_short}" -eq 1 ]; then
    SCRIPT_SUPPORTS_TTY_WRAPPER=1
    SCRIPT_TTY_WRAPPER_STYLE=short
    return 0
  fi

  SCRIPT_TTY_WRAPPER_STYLE=
  SCRIPT_SUPPORTS_TTY_WRAPPER=0
  return 1
}

