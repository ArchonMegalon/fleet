#!/usr/bin/env bash
set -euo pipefail

export CODEXEA2_CODEX_HOME="${CODEXEA2_CODEX_HOME:-/home/tibor/.codexea2}"
export CODEX_HOME="${CODEXEA2_CODEX_HOME}"
unset CODEX_CONFIG
mkdir -p "${CODEX_HOME}"
cat > "${CODEX_HOME}/config.toml" <<'EOF'
approval_policy = "never"
sandbox_mode = "danger-full-access"
service_tier = "fast"

[notice]
hide_rate_limit_model_nudge = true

[projects."/docker"]
trust_level = "trusted"

[projects."/docker/fleet"]
trust_level = "trusted"

[projects."/home/tibor"]
trust_level = "trusted"
EOF

export CODEXEA_DEFAULT_LANE="${CODEXEA_DEFAULT_LANE:-easy}"
export CODEXEA_USE_LIVE_PROFILE_MODELS="${CODEXEA_USE_LIVE_PROFILE_MODELS:-0}"
export CODEXEA_EASY_MODEL="${CODEXEA_EASY_MODEL:-onemin:gpt-5.4}"
export CODEXEA_EASY_SUBMODE="${CODEXEA_EASY_SUBMODE:-responses_fast}"
export CODEXEA_INTERACTIVE_EASY_SUBMODE="${CODEXEA_INTERACTIVE_EASY_SUBMODE:-responses_fast}"
export CODEXEA_INTERACTIVE_ALWAYS_EASY="${CODEXEA_INTERACTIVE_ALWAYS_EASY:-1}"
export CODEXEA_EASY_REASONING_EFFORT="${CODEXEA_EASY_REASONING_EFFORT:-xhigh}"
export CODEXEA_NO_ALT_SCREEN="${CODEXEA_NO_ALT_SCREEN:-0}"
export CODEXEA_TRACE_STARTUP="${CODEXEA_TRACE_STARTUP:-1}"
export CODEXEA_STARTUP_STATUS="${CODEXEA_STARTUP_STATUS:-0}"
export CODEXEA_STARTUP_STATUS_COMPACT="${CODEXEA_STARTUP_STATUS_COMPACT:-1}"
export CODEXEA_STATUS_CONNECT_TIMEOUT_SECONDS="${CODEXEA_STATUS_CONNECT_TIMEOUT_SECONDS:-1}"
export CODEXEA_STATUS_MAX_TIME_SECONDS="${CODEXEA_STATUS_MAX_TIME_SECONDS:-2}"
export CODEXEA_TRACE_HEARTBEAT_SECONDS="${CODEXEA_TRACE_HEARTBEAT_SECONDS:-20}"
export CODEXEA_DISABLE_SCRIPT_WRAPPER="${CODEXEA_DISABLE_SCRIPT_WRAPPER:-0}"
export CODEXEA_DISABLE_MCP="${CODEXEA_DISABLE_MCP:-1}"
export CODEXEA_CREDITS_INCLUDE_BILLING="${CODEXEA_CREDITS_INCLUDE_BILLING:-1}"
export CODEXEA_SKIP_GIT_REPO_CHECK="${CODEXEA_SKIP_GIT_REPO_CHECK:-1}"
export CODEXEA_PREFER_RUNTIME_AUTH="${CODEXEA_PREFER_RUNTIME_AUTH:-1}"

exec /docker/fleet/scripts/codex-shims/codexea "$@"
