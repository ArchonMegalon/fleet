def fmt(value):
    if value is None or value == "":
        return "n/a"
    if isinstance(value, float):
        if value.is_integer():
            return str(int(value))
        return f"{value:.2f}"
    return str(value)

def line(parts, widths):
    return "  ".join(str(part).ljust(width) for part, width in zip(parts, widths))

payload = json.loads(os.environ["CODEXEA_STATUS_BODY"])
workspace = os.path.basename(os.getcwd()) or os.getcwd()
principal = os.environ.get("EA_MCP_PRINCIPAL_ID") or os.environ.get("EA_PRINCIPAL_ID") or "unknown"
startup_compact = os.environ.get("CODEXEA_STATUS_STARTUP_COMPACT") == "1"

if startup_compact:
    if "providers_summary" in payload:
        providers = payload.get("providers_summary") or []
        ready = sum(1 for row in providers if row.get("state") == "ready")
        degraded = sum(1 for row in providers if row.get("state") == "degraded")
        cooldown = sum(1 for row in providers if row.get("state") == "cooldown")
        burn_1h = ((payload.get("fleet_burn") or {}).get("1h") or {}).get("provider_credits") or {}
        print(
            "CodexEA startup:"
            f" lane {fmt(payload.get('default_profile'))}->{fmt(payload.get('default_lane'))}"
            f" | ready {ready}"
            f" | degraded {degraded}"
            f" | cooldown {cooldown}"
            f" | 1h 1min burn {fmt(burn_1h.get('onemin'))} cr"
        )
    else:
        providers = ((payload.get("provider_health") or {}).get("providers") or {})
        ready = sum(1 for row in providers.values() if row.get("state") == "ready")
        degraded = sum(1 for row in providers.values() if row.get("state") == "degraded")
        print(
            "CodexEA startup:"
            f" workspace {workspace}"
            f" | principal {principal}"
            f" | ready {ready}"
            f" | degraded {degraded}"
        )
    sys.exit(0)

if "providers_summary" not in payload:
    provider_health = payload.get("provider_health") or {}
    providers = provider_health.get("providers") or {}
    print("CodexEA / Fleet Status")
    print(f"Workspace: {workspace}")
    print(f"Principal: {principal}")
    print("EA status basis: profiles_fallback")
    print("")
    print("Profiles")
    profile_headers = ["Profile", "Lane", "Model", "Providers", "Review", "Merge"]
    profile_rows = []
    for row in payload.get("profiles") or []:
        profile_rows.append([
            row.get("profile"),
            row.get("lane"),
            row.get("model"),
            ", ".join(row.get("provider_hint_order") or []),
            "yes" if row.get("review_required") else "no",
