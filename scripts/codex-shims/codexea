}

sync_runtime_auth_tokens() {
  local runtime_token=""
  local current_mcp="${EA_MCP_API_TOKEN:-}"
  local current_api="${EA_API_TOKEN:-}"
  local chosen_token=""
  runtime_env_prefers_managed_auth || return 0
  runtime_token="$(runtime_env_value EA_MCP_API_TOKEN || true)"
  if [ -z "${runtime_token}" ]; then
    runtime_token="$(runtime_env_value EA_API_TOKEN || true)"
  fi
  if [ -n "${current_mcp}" ] || [ -n "${current_api}" ]; then
    if [ -n "${runtime_token}" ]; then
      if [ -n "${current_mcp}" ] && [ "${current_mcp}" != "${runtime_token}" ] && { [ -z "${current_api}" ] || [ "${current_api}" = "${runtime_token}" ]; }; then
        chosen_token="${current_mcp}"
      elif [ -n "${current_api}" ] && [ "${current_api}" != "${runtime_token}" ] && { [ -z "${current_mcp}" ] || [ "${current_mcp}" = "${runtime_token}" ]; }; then
        chosen_token="${current_api}"
      fi
    fi
    if [ -z "${chosen_token}" ]; then
      chosen_token="${current_mcp:-${current_api}}"
    fi
    export EA_MCP_API_TOKEN="${chosen_token}"
    export EA_API_TOKEN="${chosen_token}"
    return 0
  fi
  [ -n "${runtime_token}" ] || return 0
  export EA_MCP_API_TOKEN="${runtime_token}"
  export EA_API_TOKEN="${runtime_token}"
}

sync_runtime_auth_tokens

host_resolves() {
