escape_curl_config_value() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "${value}"
}

build_ea_curl_auth_config() {
  local token="${1:-}"
  local config_path=""
  local escaped_token=""

  [ -n "${token}" ] || return 1
  config_path="$(mktemp "${TMPDIR:-/tmp}/codexea-curl-auth.XXXXXX")"
  chmod 600 "${config_path}" || true
  escaped_token="$(escape_curl_config_value "${token}")"
  {
    printf 'header = "Authorization: Bearer %s"\n' "${escaped_token}"
    printf 'header = "X-EA-Api-Token: %s"\n' "${escaped_token}"
    printf 'header = "X-API-Token: %s"\n' "${escaped_token}"
  } > "${config_path}"
  printf '%s' "${config_path}"
}

cleanup_ea_curl_auth_config() {
  local config_path="${1:-}"
  [ -n "${config_path}" ] || return 0
  rm -f "${config_path}"
}

show_status() {
  local want_json=0
  local refresh=0
  local startup_compact=0
  local watch_seconds=""
  local window="1h"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json)
        want_json=1
        ;;
      --startup)
        startup_compact=1
        ;;
      --refresh)
        refresh=1
        ;;
      --watch)
        shift
        watch_seconds="${1:-30}"
        ;;
      --window)
        shift
        window="${1:-1h}"
        ;;
      *)
        echo "Unknown status flag: $1" >&2
        return 2
        ;;
    esac
    shift || true
  done
  local -a curl_args=(
    curl
    -fsS
    --connect-timeout "${CODEXEA_STATUS_CONNECT_TIMEOUT_SECONDS}"
    --max-time "${CODEXEA_STATUS_MAX_TIME_SECONDS}"
    -H "X-EA-Principal-ID: ${EA_MCP_PRINCIPAL_ID}"
  )
  local api_token="${EA_MCP_API_TOKEN:-${EA_API_TOKEN:-}}"
  local auth_config=""
  local status_url="${EA_STATUS_URL}"
  status_url="$(append_query_param "${status_url}" "window" "${window}")"
  status_url="$(append_query_param "${status_url}" "refresh" "${refresh}")"
  if [ "${startup_compact}" -eq 1 ] && env_truthy "${CODEXEA_STARTUP_STATUS_COMPACT}"; then
    status_url="$(append_query_param "${status_url}" "compact" "1")"
  fi
  local body=""
  auth_config="$(build_ea_curl_auth_config "${api_token}" || true)"
  if [ -n "${auth_config}" ]; then
    curl_args+=(-K "${auth_config}")
  fi
  if [ -n "${watch_seconds}" ]; then
    local -a watch_args=()
    if [ "${want_json}" -eq 1 ]; then
      watch_args+=(--json)
    fi
    if [ "${refresh}" -eq 1 ]; then
      watch_args+=(--refresh)
    fi
    watch_args+=(--window "${window}")
    while true; do
      clear
      show_status "${watch_args[@]}"
      sleep "${watch_seconds}"
    done
  fi
  if ! body="$("${curl_args[@]}" "${status_url}" 2>/dev/null)"; then
    body="$("${curl_args[@]}" "${EA_PROFILES_URL}" 2>/dev/null)" || {
      cleanup_ea_curl_auth_config "${auth_config}"
      if [ "${startup_compact}" -eq 1 ]; then
        return 1
      fi
      if [ -z "${api_token}" ]; then
        echo "EA status unavailable from ${status_url} and fallback ${EA_PROFILES_URL}; EA_MCP_API_TOKEN / EA_API_TOKEN is not configured" >&2
      else
        echo "EA status unavailable from ${status_url} and fallback ${EA_PROFILES_URL}" >&2
      fi
      return 1
    }
  fi
  cleanup_ea_curl_auth_config "${auth_config}"
  if [ "${want_json}" -eq 1 ] || ! [ -t 1 ] || ! command -v python3 >/dev/null 2>&1; then
    printf '%s\n' "${body}"
    return
  fi
  CODEXEA_STATUS_BODY="${body}" CODEXEA_STATUS_STARTUP_COMPACT="${startup_compact}" python3 - <<'PY'
