    emit_post_audit_request "${REVIEW_REQUEST_FILE}"
  fi
  exit "${CODEXEA_EXIT}"
fi

if [ "${USE_CLEAN_EXEC_OUTPUT}" -eq 1 ]; then
  set +e
  run_exec_session_with_clean_output "${CODEXEA_CMD[@]}"
  CODEXEA_EXIT=$?
  set -e
  exit "${CODEXEA_EXIT}"
fi

if [ "${PROMPT_TRACE_HEARTBEAT_REQUEST}" -eq 1 ]; then
  set +e
  run_with_trace_heartbeat "${CODEXEA_CMD[@]}"
  CODEXEA_EXIT=$?
  set -e
  exit "${CODEXEA_EXIT}"
fi

exec "${CODEXEA_CMD[@]}"
