#!/usr/bin/env python3
from __future__ import annotations

import errno
import fcntl
import os
import pty
import select
import signal
import socket
import sys
import termios
import time
import tty
from typing import Callable


DEFAULT_INTERVAL = int(os.environ.get("CODEXEA_WATCHDOG_INTERVAL", "30"))
DEFAULT_PROMPT = os.environ.get(
    "CODEXEA_WATCHDOG_PROMPT",
    "Trace: continue with the next obvious unfinished implementation slice and keep working until there is no actionable work left.",
)
DEFAULT_INTERRUPT_INTERVALS = int(os.environ.get("CODEXEA_WATCHDOG_INTERRUPT_INTERVALS", "2"))


def _set_nonblocking(fd: int) -> None:
    flags = fcntl.fcntl(fd, fcntl.F_GETFL)
    fcntl.fcntl(fd, fcntl.F_SETFL, flags | os.O_NONBLOCK)


def _sync_winsize(from_fd: int, to_fd: int) -> None:
    try:
        winsize = fcntl.ioctl(from_fd, termios.TIOCGWINSZ, b"\0" * 8)
        fcntl.ioctl(to_fd, termios.TIOCSWINSZ, winsize)
    except OSError:
        pass


def _write_all(fd: int, data: bytes) -> None:
    view = memoryview(data)
    while view:
        try:
            written = os.write(fd, view)
            view = view[written:]
        except (BlockingIOError, InterruptedError):
            select.select([], [fd], [], 0.25)
        except OSError as exc:
            if exc.errno in (socket.EAGAIN, socket.EWOULDBLOCK):
                select.select([], [fd], [], 0.25)
                continue
            raise


def main(argv: list[str]) -> int:
    codexea = os.environ.get("CODEXEA_WATCHDOG_TARGET", os.path.expanduser("~/.local/bin/codexea"))
    interval = DEFAULT_INTERVAL
    prompt = DEFAULT_PROMPT
    child_argv = [codexea, *argv]

    if not os.path.exists(codexea):
        print(f"Missing codexea launcher: {codexea}", file=sys.stderr)
        return 1

    master_fd, slave_fd = pty.openpty()
    stdin_fd = sys.stdin.fileno()
    stdin_is_tty = os.isatty(stdin_fd)
    old_tty = termios.tcgetattr(stdin_fd) if stdin_is_tty else None
    previous_winch_handler: int | Callable[[int, object], None] | None = None
    if stdin_is_tty:
        _sync_winsize(stdin_fd, slave_fd)
    child_pid = os.fork()
    if child_pid == 0:
        try:
            os.setsid()
            os.close(master_fd)
            os.dup2(slave_fd, 0)
            os.dup2(slave_fd, 1)
            os.dup2(slave_fd, 2)
            if slave_fd > 2:
                os.close(slave_fd)
            os.environ["CODEXEA_WATCHDOG_ACTIVE"] = "1"
            os.execv(child_argv[0], child_argv)
        finally:
            os._exit(127)

    os.close(slave_fd)
    if stdin_is_tty:
        tty.setraw(stdin_fd)
    _set_nonblocking(master_fd)
    if stdin_is_tty:
        _set_nonblocking(stdin_fd)
        def _handle_winch(signum: int, frame: object) -> None:
            _sync_winsize(stdin_fd, master_fd)
            try:
                os.kill(child_pid, signal.SIGWINCH)
            except ProcessLookupError:
                pass
        previous_winch_handler = signal.signal(signal.SIGWINCH, _handle_winch)

    last_activity = time.monotonic()
    idle_nudges = 0

    try:
        while True:
            now = time.monotonic()
            timeout = max(0.25, interval - (now - last_activity))
            watched_fds = [master_fd]
            if stdin_is_tty:
                watched_fds.append(stdin_fd)
            rlist, _, _ = select.select(watched_fds, [], [], timeout)

            if master_fd in rlist:
                try:
                    data = os.read(master_fd, 65536)
                except BlockingIOError:
                    data = b""
                except OSError as exc:
                    if exc.errno == errno.EIO:
                        data = b""
                    else:
                        raise
                if not data:
                    break
                _write_all(sys.stdout.fileno(), data)
                last_activity = time.monotonic()
                idle_nudges = 0

            if stdin_is_tty and stdin_fd in rlist:
                try:
                    user_data = os.read(stdin_fd, 65536)
                except BlockingIOError:
                    user_data = b""
                if user_data:
                    os.write(master_fd, user_data)
                    last_activity = time.monotonic()
                    idle_nudges = 0

            now = time.monotonic()
            if now - last_activity >= interval:
                idle_nudges += 1
                if idle_nudges >= DEFAULT_INTERRUPT_INTERVALS:
                    os.write(master_fd, b"\x03")
                    time.sleep(0.2)
                    os.write(
                        master_fd,
                        ("\n" + prompt + "\n").encode("utf-8", "ignore"),
                    )
                    _write_all(
                        sys.stdout.fileno(),
                        b"\n[watchdog] interrupted idle codexea and sent continue prompt\n",
                    )
                else:
                    os.write(
                        master_fd,
                        ("\n" + prompt + "\n").encode("utf-8", "ignore"),
                    )
                    _write_all(
                        sys.stdout.fileno(),
                        b"\n[watchdog] nudged codexea after idle interval\n",
                    )
                last_activity = time.monotonic()

            pid, status = os.waitpid(child_pid, os.WNOHANG)
            if pid == child_pid:
                if os.WIFEXITED(status):
                    return os.WEXITSTATUS(status)
                if os.WIFSIGNALED(status):
                    return 128 + os.WTERMSIG(status)
                return 1
    except KeyboardInterrupt:
        try:
            os.kill(child_pid, signal.SIGINT)
        except ProcessLookupError:
            pass
        return 130
    finally:
        if stdin_is_tty and old_tty is not None:
            termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_tty)
        if previous_winch_handler is not None:
            signal.signal(signal.SIGWINCH, previous_winch_handler)
        os.close(master_fd)

    pid, status = os.waitpid(child_pid, 0)
    if os.WIFEXITED(status):
        return os.WEXITSTATUS(status)
    if os.WIFSIGNALED(status):
        return 128 + os.WTERMSIG(status)
    return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
