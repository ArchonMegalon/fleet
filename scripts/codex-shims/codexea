append_exec_json_flag() {
  local -a args=("$@")
  local -a rendered=()
  local arg
  local inserted=0

  for arg in "${args[@]}"; do
    if [ "${arg}" = "--json" ]; then
      printf '%s\0' "${args[@]}"
      return
    fi
  done

  for arg in "${args[@]}"; do
    rendered+=("${arg}")
    if [ "${inserted}" -eq 0 ] && [ "${arg}" = "exec" ]; then
      rendered+=(--json)
      inserted=1
    fi
  done

  printf '%s\0' "${rendered[@]}"
}

