debug_render_args() {
  python3 - "$@" <<'PY'
import shlex
import sys

parts = []
for arg in sys.argv[1:]:
    display = arg
    if "\n" in display or len(display) > 120:
        display = f"<arg:{len(arg)} chars>"
    parts.append(shlex.quote(display))
print(" ".join(parts))
PY
}

emit_debug_trace() {
  local detail="${1:-}"
  local lane="${EFFECTIVE_LANE:-${REQUESTED_LANE:-${CODEXEA_DEFAULT_LANE:-easy}}}"
  local line=""
  env_truthy "${CODEXEA_DEBUG}" || return 0
  mkdir -p "${CODEXEA_STATE_DIR}" >/dev/null 2>&1 || true
  line="Trace: lane=${lane} debug=${detail}"
  printf '%s\n' "${line}" >&2
  printf '%s\n' "${line}" >> "${CODEXEA_DEBUG_LOG_FILE}" 2>/dev/null || true
}

emit_debug_command() {
  local phase="${1:-launch}"
  local rendered=""
  shift || true
  env_truthy "${CODEXEA_DEBUG}" || return 0
  rendered="$(debug_render_args "$@")"
  emit_debug_trace "${phase} command=${rendered}"
}

